@using System.Security.Claims
@using BookWarehouse.Application.Abstractions
@using BookWarehouse.Application.Comman.Constants
@inject ICartService CartService
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - BookWarehouse.Presentation</title>
    <script type="importmap"></script>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/BookWarehouse.Presentation.styles.css" asp-append-version="true" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.13.1/font/bootstrap-icons.min.css"> 
    <link rel="stylesheet" href="//cdn.datatables.net/2.3.7/css/dataTables.bootstrap5.min.css" />
    <link rel="stylesheet" href="//cdnjs.cloudflare.com/ajax/libs/toastr.js/latest/css/toastr.min.css" />
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="//cdnjs.cloudflare.com/ajax/libs/toastr.js/latest/js/toastr.min.js"></script>
    
</head>
<body>
    @{
            int cartCount = 0;
            if (User.Identity!.IsAuthenticated && User.IsInRole(DefaultRole.Customer))
            {
                var userId = User.FindFirstValue(ClaimTypes.NameIdentifier);
                if (userId != null)
                {
                    var cartResult = await CartService.GetAllUserCartProducts(userId);
                    if (cartResult.IsSuccess)
                    {
                        // cartCount = cartResult.Value.Sum(c => c.Count);

                        cartCount = cartResult.Value.Count();
                    }
            }
        }
    }
    <header class="navbar navbar-expand-lg py-3 sticky-top" style="background-color: rgba(252, 250, 250, 0.95); backdrop-filter: blur(16px); -webkit-backdrop-filter: blur(16px); border-bottom: 1px solid rgba(231, 229, 228, 0.8); z-index: 1030; transition: all 0.3s ease;">
        <div class="container-fluid px-md-5">
            <!-- Logo -->
            <a class="navbar-brand d-flex align-items-center" asp-area="" asp-controller="Home" asp-action="Index">
                <div class="bg-primary text-white rounded d-flex align-items-center justify-content-center me-2 shadow-sm" style="width: 35px; height: 35px;">
                    <i class="bi bi-book-half" style="font-size: 1.1rem;"></i>
                </div>
                Readify<span class="text-primary">.</span>
            </a>

            <!-- Toggler -->
            <button class="navbar-toggler border-0 shadow-none" type="button" data-bs-toggle="collapse" data-bs-target="#navbarContent" aria-controls="navbarContent" aria-expanded="false" aria-label="Toggle navigation">
                <span class="navbar-toggler-icon"></span>
            </button>

            <div class="collapse navbar-collapse" id="navbarContent">
                <!-- Navigation Links (Centered) -->
                <ul class="navbar-nav mx-auto mb-2 mb-lg-0 gap-lg-3">
                    <li class="nav-item">
                        <a class="nav-link px-2 text-dark" style="font-weight: 600;" asp-controller="Home" asp-action="Index">Home</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link px-2 text-dark" style="font-weight: 600;" asp-controller="Category" asp-action="Index">Categories</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link px-2 text-dark" style="font-weight: 600;" asp-controller="CustomerProduct" asp-action="Index">Products</a>
                    </li>
                    @if (User.IsInRole(DefaultRole.Customer))
                    {
                        <li class="nav-item">
                            <a class="nav-link px-2 text-dark" style="font-weight: 600;" asp-controller="Order" asp-action="GetAllUserOders">My Orders</a>
                        </li>
                    }
                </ul>

                <!-- Actions -->
                <div class="d-flex align-items-center gap-4 mt-3 mt-lg-0">
                    <!-- Cart -->
                    <a asp-controller="Cart" asp-action="Index" class="text-dark position-relative text-decoration-none d-flex align-items-center transition" style="opacity: 0.8;" onmouseover="this.style.opacity='1'" onmouseout="this.style.opacity='0.8'">
                        <i class="bi bi-cart3 fs-5"></i>
                        @if (cartCount > 0)
                        {
                            <span class="position-absolute top-0 start-100 translate-middle badge rounded-pill border border-white shadow-sm" style="font-size: 0.65rem; background-color: var(--accent-coral); color: white;">
                                @cartCount
                            </span>
                        }
                    </a>

                    <!-- User / Auth -->
                    @if (User.Identity!.IsAuthenticated)
                    {
                        var displayName = User.Identity.Name?.Split('@')[0] ?? "Profile";
                        <div class="dropdown">
                            <button class="btn btn-link text-dark text-decoration-none p-0 d-flex align-items-center gap-2" type="button" id="userMenu" data-bs-toggle="dropdown" aria-expanded="false" style="opacity: 0.8;" onmouseover="this.style.opacity='1'" onmouseout="this.style.opacity='0.8'">
                                <i class="bi bi-person fs-5"></i>
                                <span class="d-none d-sm-inline fw-semibold" style="font-size: 0.95rem;">@displayName</span>
                                <i class="bi bi-chevron-down" style="font-size: 0.75rem;"></i>
                            </button>
                            <ul class="dropdown-menu dropdown-menu-end shadow-sm border-0 mt-3" aria-labelledby="userMenu" style="border-radius: 12px; min-width: 150px; padding: 0.5rem;">
                                <li>
                                    <a class="dropdown-item py-2 fw-medium text-danger d-flex align-items-center gap-2 rounded transition" onmouseover="this.style.backgroundColor='#fee2e2'" onmouseout="this.style.backgroundColor='transparent'" asp-controller="Auth" asp-action="Logout">
                                        <i class="bi bi-box-arrow-right"></i> Logout
                                    </a>
                                </li>
                            </ul>
                        </div>
                    }
                    else
                    {
                        <a asp-controller="Auth" asp-action="Login" class="text-dark text-decoration-none d-flex align-items-center gap-2 fw-semibold" style="font-size: 0.95rem; opacity: 0.8;" onmouseover="this.style.opacity='1'" onmouseout="this.style.opacity='0.8'">
                            <i class="bi bi-person fs-5"></i> Sign in
                        </a>
                    }
                </div>
            </div>
        </div>
    </header>

    <div class="container-fluid px-md-5">
        <main role="main" class="pb-5 pt-3">
            <partial name="_Notification" />
            @RenderBody()
        </main>
    </div>

    <footer class="footer py-5 mt-auto">
        <div class="container-fluid px-md-5">
            <div class="row g-4">
                <div class="col-lg-4 mb-4 mb-lg-0">
                    <a class="text-decoration-none d-flex align-items-center fw-bolder fs-3 mb-3 text-dark" asp-area="" asp-controller="Home" asp-action="Index">
                        <div class="bg-primary text-white rounded d-flex align-items-center justify-content-center me-2 shadow-sm" style="width: 35px; height: 35px;">
                            <i class="bi bi-book-half" style="font-size: 1.1rem;"></i>
                        </div>
                        Readify<span class="text-primary">.</span>
                    </a>
                    <p class="text-muted" style="font-size: 0.95rem; max-width: 300px;">Your ultimate destination for discovering, reading, and loving books. We bring stories to life with every page.</p>
                </div>
                <div class="col-lg-2 col-md-4">
                    <h6 class="fw-bold mb-3 text-dark">Shop</h6>
                    <ul class="list-unstyled d-flex flex-column gap-2 mb-0" style="font-size: 0.95rem;">
                        <li><a asp-controller="CustomerProduct" asp-action="Index" class="text-muted text-decoration-none transition" onmouseover="this.style.color='#2563eb'" onmouseout="this.style.color='var(--brand-muted)'">All Books</a></li>
                        <li><a asp-controller="Category" asp-action="Index" class="text-muted text-decoration-none transition" onmouseover="this.style.color='#2563eb'" onmouseout="this.style.color='var(--brand-muted)'">Categories</a></li>
                        <li><a href="#" class="text-muted text-decoration-none transition" onmouseover="this.style.color='#2563eb'" onmouseout="this.style.color='var(--brand-muted)'">Best Sellers</a></li>
                    </ul>
                </div>
                <div class="col-lg-2 col-md-4">
                    <h6 class="fw-bold mb-3 text-dark">Account</h6>
                    <ul class="list-unstyled d-flex flex-column gap-2 mb-0" style="font-size: 0.95rem;">
                        <li><a asp-controller="Auth" asp-action="Login" class="text-muted text-decoration-none transition" onmouseover="this.style.color='#2563eb'" onmouseout="this.style.color='var(--brand-muted)'">Sign In</a></li>
                        <li><a asp-controller="Cart" asp-action="Index" class="text-muted text-decoration-none transition" onmouseover="this.style.color='#2563eb'" onmouseout="this.style.color='var(--brand-muted)'">View Cart</a></li>
                        <li><a asp-controller="Order" asp-action="GetAllUserOders" class="text-muted text-decoration-none transition" onmouseover="this.style.color='#2563eb'" onmouseout="this.style.color='var(--brand-muted)'">My Orders</a></li>
                    </ul>
                </div>
                <div class="col-lg-4 col-md-4">
                    <h6 class="fw-bold mb-3 text-dark">Stay Connected</h6>
                    <p class="text-muted mb-3" style="font-size: 0.95rem;">Subscribe to our newsletter for updates and exclusive offers.</p>
                    <div class="input-group mb-3 shadow-sm" style="max-width: 300px; border-radius: 12px; overflow: hidden; border: 1px solid var(--border-color);">
                        <input type="email" class="form-control border-0 shadow-none bg-white" placeholder="Email address" aria-label="Email address" style="font-size: 0.95rem; height: 45px;">
                        <button class="btn btn-primary border-0 rounded-0 px-3 m-0" type="button" style="font-weight: 500;">Subscribe</button>
                    </div>
                </div>
            </div>
            <hr class="my-4" style="border-color: var(--border-color); opacity: 1;">
            <div class="d-flex flex-column flex-md-row justify-content-between align-items-center">
                <span class="text-muted" style="font-size: 0.85rem;">&copy; @DateTime.Now.Year Readify. All rights reserved.</span>
                <span class="text-muted mt-2 mt-md-0" style="font-size: 0.85rem;">Made with <i class="bi bi-heart-fill text-danger"></i></span>
            </div>
        </div>
    </footer>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    <script src="//cdn.datatables.net/2.3.7/js/dataTables.min.js" asp-append-version="true"></script>
    <script src="//cdn.datatables.net/2.3.7/js/dataTables.bootstrap5.min.js" asp-append-version="true"></script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
