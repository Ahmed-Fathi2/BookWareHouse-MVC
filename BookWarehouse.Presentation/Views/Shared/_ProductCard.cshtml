@model ProductReadVM

<div class="col-12 col-sm-6 col-md-4 col-lg-3 mb-4">
    <div class="card h-100 shadow-sm border-0 position-relative" style="border-radius: 16px; overflow: hidden; transition: transform 0.3s ease, box-shadow 0.3s ease;" onmouseover="this.style.transform='translateY(-5px)'; this.style.boxShadow='0 15px 35px rgba(0,0,0,0.1)';" onmouseout="this.style.transform='translateY(0)'; this.style.boxShadow='0 5px 15px rgba(0,0,0,0.05)';">
        
        <!-- Category Badge -->
        <span class="badge bg-white text-primary position-absolute top-0 end-0 m-3 px-3 py-2 shadow-sm border" style="z-index: 2; border-radius: 20px; font-weight: 700;">@Model.CategoryName</span>

        <!-- Card Image -->
        <div class="position-relative bg-white" style="border-bottom: 1px solid #f8f9fa; height: 220px; overflow: hidden;">
            @if(string.IsNullOrWhiteSpace(Model.ImageUrl))
            {
                <div class="d-flex justify-content-center align-items-center h-100">
                    <i class="bi bi-image text-muted text-opacity-25" style="font-size: 6rem;"></i>
                </div>
            }
            else
            {
                <img src="~/@Model.ImageUrl" alt="@Model.Title" class="w-100 h-100" style="object-fit: cover; display: block;" />
            }
        </div>
        
        <div class="card-body d-flex flex-column p-4">
            <h5 class="card-title fw-bold text-primary mb-1 text-truncate" title="@Model.Title">@Model.Title</h5>
            <p class="text-muted small mb-3"><i class="bi bi-pen-fill me-1"></i> @Model.Author</p>
            
            <p class="card-text text-secondary mb-3" style="display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden; font-size: 0.9rem; min-height: 42px;">
                @(string.IsNullOrWhiteSpace(Model.Description) ? "No description available." : Model.Description)
            </p>
            
            <div class="mt-auto d-flex flex-column pt-3 border-top">
                <div class="d-flex justify-content-between align-items-center mb-3">
                    <span class="fs-4 fw-bold text-primary">$@Model.Price</span>
                    @if(Model.ListPrice > 0)
                    {
                        <span class="text-muted text-decoration-line-through small fw-semibold">$@Model.ListPrice</span>
                    }
                </div>
                <a asp-controller="CustomerProduct" asp-action="Details" asp-route-id="@Model.Id" class="btn btn-primary w-100 shadow-sm" style="border-radius: 8px; font-weight: 700; padding: 0.6rem; transition: transform 0.2s ease, box-shadow 0.2s ease;" onmouseover="this.classList.replace('shadow-sm','shadow'); this.style.transform='translateY(-2px)';" onmouseout="this.classList.replace('shadow','shadow-sm'); this.style.transform='translateY(0)';">
                    <i class="bi bi-info-circle me-1"></i> Details
                </a>
            </div>
        </div>
    </div>
</div>
