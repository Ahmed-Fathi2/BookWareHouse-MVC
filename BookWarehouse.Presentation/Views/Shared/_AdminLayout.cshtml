@using System.Security.Claims
@using BookWarehouse.Application.Comman.Constants
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Admin Dashboard</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <link rel="stylesheet" href="~/css/admin.css" asp-append-version="true" />
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="//cdnjs.cloudflare.com/ajax/libs/toastr.js/latest/css/toastr.min.css" />
    <link rel="stylesheet" href="//cdn.datatables.net/2.3.7/css/dataTables.bootstrap5.min.css" />
</head>
<body>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="//cdn.datatables.net/2.3.7/js/dataTables.min.js" asp-append-version="true"></script>
    <script src="//cdn.datatables.net/2.3.7/js/dataTables.bootstrap5.min.js" asp-append-version="true"></script>
    <script src="//cdnjs.cloudflare.com/ajax/libs/toastr.js/latest/js/toastr.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    
    <div class="admin-wrapper">
        <!-- Sidebar -->
        <aside class="sidebar">
            <div class="sidebar-header">
                <i class="bi bi-book-half me-2"></i> Readify
            </div>
            
            <div class="sidebar-content">
                <div class="sidebar-section-title">Workspace</div>
                <div class="nav-item">
                    <a class="nav-link-admin @(ViewContext.RouteData.Values["Controller"]?.ToString() == "DashBoard" && ViewContext.RouteData.Values["Action"]?.ToString() == "Index" ? "active" : "")" asp-controller="DashBoard" asp-action="Index">
                        <i class="bi bi-grid-1x2-fill"></i> Dashboard
                    </a>
                </div>
                <div class="nav-item">
                    <a class="nav-link-admin @(ViewContext.RouteData.Values["Controller"]?.ToString() == "Order" ? "active" : "")" asp-controller="Order" asp-action="Index">
                        <i class="bi bi-cart-fill"></i> Orders
                    </a>
                </div>
                <div class="nav-item">
                    <a class="nav-link-admin @(ViewContext.RouteData.Values["Controller"]?.ToString() == "AdminProduct" ? "active" : "")" asp-controller="AdminProduct" asp-action="Index">
                        <i class="bi bi-box-seam-fill"></i> Products
                    </a>
                </div>
                <div class="nav-item">
                    <a class="nav-link-admin @(ViewContext.RouteData.Values["Controller"]?.ToString() == "Category" ? "active" : "")" asp-controller="Category" asp-action="Index">
                        <i class="bi bi-tags-fill"></i> Categories
                    </a>
                </div>
                <div class="nav-item">


                    <a class="nav-link-admin @(ViewContext.RouteData.Values["Controller"]?.ToString() == "DashBoard" && ViewContext.RouteData.Values["Action"]?.ToString() == "CustomerDetails" ? "active" : "")" asp-controller="DashBoard" asp-action="CustomerDetails">
                        <i class="bi bi-people-fill"></i> Customers
                    </a>
                </div>
            </div>

            <div class="sidebar-footer">
                <div class="user-profile">
                    <div class="user-avatar">
                        @{
                            var name = User.Identity?.Name ?? "Admin";
                            var initials = name.Substring(0, Math.Min(2, name.Length)).ToUpper();
                        }
                        @initials
                    </div>
                    <div class="user-info">
                        <span class="user-name">@User.Identity?.Name</span>
                        <span class="user-email text-muted">@User.FindFirstValue(ClaimTypes.Email)</span>
                    </div>
                </div>
                <div class="nav-item p-0">
                    <a class="nav-link-admin text-danger" asp-controller="Auth" asp-action="Logout">
                        <i class="bi bi-box-arrow-right"></i> Sign out
                    </a>
                </div>
            </div>
        </aside>

        <!-- Main Content -->
        <main class="main-content">
            <partial name="_Notification" />
            @RenderBody()
        </main>
    </div>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
