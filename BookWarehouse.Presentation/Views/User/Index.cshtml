@model IEnumerable<BookWarehouse.Application.ViewModels.User.UserListVM>

@{
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
    ViewData["Title"] = "User Management";
}

<div class="container-fluid mt-4 mb-5 pb-5 px-md-2">
    <div class="d-flex flex-column flex-md-row justify-content-between align-items-start align-items-md-center mb-4 gap-3">
        <div>
            <h2 class="fw-bold text-primary mb-1"><i class="bi bi-people-fill me-2"></i>Users List</h2>
            <p class="text-muted mb-0">Manage all registered users and administrators.</p>
        </div>
        <a asp-action="Create" class="btn btn-primary btn-lg shadow-sm">
            <i class="bi bi-plus-circle-fill"></i> Add New User
        </a>
    </div>

    <div class="card border border-light shadow-sm overflow-hidden" style="border-radius: 12px; background-color: #ffffff;">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table align-middle mb-0 w-100 border-0">
                    <thead style="background-color: #f8fafc; border-bottom: 1px solid #e2e8f0;">
                        <tr>
                            <th class="py-3 px-4 text-uppercase border-0" style="font-size: 0.75rem; color: #64748b; font-weight: 700; letter-spacing: 0.5px;">Name</th>
                            <th class="py-3 text-uppercase border-0" style="font-size: 0.75rem; color: #64748b; font-weight: 700; letter-spacing: 0.5px;">Email</th>
                            <th class="py-3 text-uppercase border-0" style="font-size: 0.75rem; color: #64748b; font-weight: 700; letter-spacing: 0.5px;">Role(s)</th>
                            <th class="py-3 text-center text-uppercase border-0" style="font-size: 0.75rem; color: #64748b; font-weight: 700; letter-spacing: 0.5px;">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var user in Model)
                        {
                            <tr style="border-bottom: 1px solid #f1f5f9;">
                                <td class="ps-4 py-3 fw-bold text-dark">
                                    <div class="d-flex align-items-center gap-2">
                                        <div class="bg-primary text-white rounded-circle d-flex align-items-center justify-content-center fw-bold shadow-sm" style="width: 40px; height: 40px; font-size: 1.1rem;">
                                            @user.FirstName?.FirstOrDefault()@user.LastName?.FirstOrDefault()
                                        </div>
                                        <span>@user.FirstName @user.LastName</span>
                                    </div>
                                </td>
                                <td class="text-muted">@user.Email</td>
                                <td>
                                    @foreach(var role in user.Roles)
                                    {
                                        <span class="badge bg-light text-primary border px-2 py-1 me-1">@role</span>
                                    }
                                </td>
                                <td>
                                    <div class="d-flex justify-content-center align-items-center gap-2">
                                        <form asp-action="Delete" asp-route-id="@user.Id" method="post" class="delete-user-form">
                                            <button type="button" class="btn btn-sm btn-white border shadow-sm rounded-3 px-2 text-danger hover-bg-light delete-user-btn">
                                                <i class="bi bi-trash-fill"></i>
                                            </button>
                                        </form>
                                    </div>
                                </td>
                            </tr>
                        }
                        @if (!Model.Any())
                        {
                            <tr>
                                <td colspan="4" class="text-center py-5 text-muted border-0">
                                    <i class="bi bi-people fs-1 d-block mb-3"></i>
                                    <h5 class="fw-bold text-dark">No Users Found</h5>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        $(document).ready(function () {
            $('.delete-user-btn').on('click', function (e) {
                e.preventDefault();
                var form = $(this).closest('.delete-user-form');
                
                Swal.fire({
                    title: 'Are you sure?',
                    text: "You won't be able to revert this! The user will be permanently deleted.",
                    icon: 'warning',
                    showCancelButton: true,
                    confirmButtonColor: '#d33',
                    cancelButtonColor: '#3085d6',
                    confirmButtonText: 'Yes, delete it!'
                }).then((result) => {
                    if (result.isConfirmed) {
                        form.submit();
                    }
                });
            });
        });
    </script>
}
