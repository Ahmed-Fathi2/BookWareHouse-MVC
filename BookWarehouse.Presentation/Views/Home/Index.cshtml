@model BookWarehouse.Application.ViewModels.Home.HomeIndexVM
@{
    ViewData["Title"] = "Home Page";
}

<div class="container-fluid px-md-5 py-5" style="background-color: var(--bg-main); min-height: 100vh;">
    
    <!-- HERO SECTION -->
    <div class="row align-items-center mb-5 min-vh-75">
        <!-- Left Text Area -->
        <div class="col-lg-6 d-flex flex-column justify-content-center pe-lg-5 mb-5 mb-lg-0">
            <div>
                <span class="badge bg-white border text-dark fw-medium rounded-pill px-3 py-2 shadow-sm mb-4 d-inline-flex align-items-center gap-2" style="font-size: 0.85rem; border-color: var(--border-color) !important;">
                    <i class="bi bi-stars" style="color: var(--accent-coral); font-size: 1rem;"></i> New season — up to 30% off
                </span>
                
                <h1 class="display-4 fw-bolder mb-3" style="color: var(--brand-dark); font-size: 3.5rem; line-height: 1.15; letter-spacing: -1px;">
                    Modern essentials,<br/>
                    <span class="text-primary">delivered.</span>
                </h1>
                
                <p class="text-muted mb-4 fs-5" style="max-width: 90%;">
                    Discover thoughtfully designed products from independent brands. Premium quality, fair prices, fast shipping.
                </p>
                
                <form method="get" asp-controller="CustomerProduct" asp-action="Index" class="mb-4">
                    <div class="input-group shadow-sm bg-white p-1" style="max-width: 480px; height: 56px; border-radius: 16px; border: 1px solid var(--border-color);">
                        <span class="input-group-text bg-transparent border-0 text-muted px-3">
                            <i class="bi bi-search" style="font-size: 1.1rem;"></i>
                        </span>
                        <input type="text" name="SearchValue" class="form-control border-0 shadow-none fw-medium bg-transparent px-0" placeholder="Search products, brands, categories" style="font-size: 0.95rem; color: var(--brand-dark);">
                        <button type="submit" class="btn btn-primary m-1 px-4" style="border-radius: 12px; font-weight: 600; font-size: 0.95rem;">
                            Search
                        </button>
                    </div>
                </form>

                <div class="d-flex gap-3">
                    <a asp-controller="CustomerProduct" asp-action="Index" class="btn btn-primary px-4 py-2 shadow-sm">
                        Shop all <i class="bi bi-arrow-right"></i>
                    </a>
                    <a href="#categories" class="btn btn-outline px-4 py-2 shadow-sm fw-semibold">
                        Browse categories
                    </a>
                </div>
            </div>
        </div>

        <!-- Right Images Area -->
        <div class="col-lg-6">
            <div class="d-grid h-100" style="grid-template-columns: 1fr 1fr; gap: 1.25rem;">
                <!-- Main book image -->
                <div class="w-100 h-100 shadow-sm" style="background-color: #f3e5d8; border-radius: 20px; min-height: 400px; background-image: url('/images/hero/hero_main_books.png'); background-size: cover; background-position: center;"></div>
                
                <div class="d-flex flex-column h-100" style="gap: 1.25rem;">
                    <div class="w-100 shadow-sm" style="height: calc(50% - 0.625rem); background-color: #e2e8f0; border-radius: 20px; background-image: url('/images/hero/hero_reading_book.png'); background-size: cover; background-position: center;"></div>
                    <div class="w-100 shadow-sm" style="height: calc(50% - 0.625rem); background-color: #e2e8f0; border-radius: 20px; background-image: url('/images/hero/hero_bookshelf_modern_v2.png'); background-size: cover; background-position: center;"></div>
                </div>
            </div>
        </div>
    </div>

    <!-- CATEGORIES SECTION -->
    <div id="categories" class="mb-5 pt-4">
        <div class="d-flex flex-column flex-sm-row justify-content-between align-items-start align-items-sm-end mb-4 gap-2">
            <div>
                <h3 class="fw-bolder mb-1 text-dark" style="font-size: 1.8rem; letter-spacing: -0.5px;">Shop by category</h3>
                <p class="text-muted mb-0" style="font-size: 0.95rem;">Explore curated collections.</p>
            </div>
            <a asp-controller="Category" asp-action="Index" class="text-decoration-none fw-bold text-primary" style="font-size: 0.95rem;">
                View all <i class="bi bi-arrow-right ms-1"></i>
            </a>
        </div>
        
        <div class="row g-3">
            @foreach(var cat in Model.Categories.Take(6))
            {
                <div class="col-6 col-md-4 col-lg-2">
                    <a asp-controller="CustomerProduct" asp-action="Index" asp-route-CategoryId="@cat.Id" class="text-decoration-none d-block h-100">
                        <div class="card border-0 shadow-sm category-hover h-100 position-relative" style="border-radius: 16px; overflow: hidden; background-color: var(--bg-white); transition: all 0.3s ease; aspect-ratio: 1/1;">
                            
                            @if(string.IsNullOrWhiteSpace(cat.ImageUrl))
                            {
                                <div class="w-100 h-100 d-flex justify-content-center align-items-center">
                                    <i class="bi bi-image text-muted text-opacity-25" style="font-size: 3rem;"></i>
                                </div>
                            }
                            else
                            {
                                <img src="/@cat.ImageUrl" alt="@cat.Name" class="w-100 h-100 position-absolute" style="object-fit: cover; top: 0; left: 0;" />
                            }
                            
                            <!-- Dark Gradient Overlay -->
                            <div class="position-absolute w-100" style="bottom: 0; left: 0; height: 60%; background: linear-gradient(to top, rgba(0,0,0,0.85) 0%, rgba(0,0,0,0) 100%);"></div>

                            <!-- Text Content -->
                            <div class="position-absolute w-100 p-3" style="bottom: 0; left: 0; text-align: left;">
                                <h6 class="fw-bold text-white mb-1 text-truncate" style="font-size: 1.05rem;">@cat.Name</h6>
                                <span class="text-white text-opacity-75 fw-medium" style="font-size: 0.75rem;">@cat.NumOfProducts items</span>
                            </div>

                        </div>
                    </a>
                </div>
            }
        </div>
    </div>

    <!-- FEATURED PRODUCTS SECTION -->
    <div class="mb-5 pt-2">
        <div class="d-flex flex-column flex-sm-row justify-content-between align-items-start align-items-sm-end mb-4 gap-2">
            <div>
                <h3 class="fw-bolder mb-1 text-dark" style="font-size: 1.8rem; letter-spacing: -0.5px;">Featured products</h3>
                <p class="text-muted mb-0" style="font-size: 0.95rem;">Handpicked favorites from our collection.</p>
            </div>
            <a asp-controller="CustomerProduct" asp-action="Index" class="text-decoration-none fw-bold text-primary" style="font-size: 0.95rem;">
                Shop all <i class="bi bi-arrow-right ms-1"></i>
            </a>
        </div>

        <div class="row g-4">
            @foreach(var product in Model.FeaturedProducts.Take(4))
            {
                <div class="col-12 col-sm-6 col-md-4 col-lg-3">
                    <div class="card h-100 border-0 shadow-sm product-card position-relative" style="border-radius: 16px; overflow: hidden; background-color: var(--bg-white);">
                        
                        <!-- Image Header -->
                        <div class="position-relative overflow-hidden" style="height: 220px; background-color: #f8fafc;">
                            <!-- Badges -->
                            <div class="position-absolute top-0 start-0 m-3 d-flex flex-column gap-1" style="z-index: 2;">
                                @if(product.ListPrice > 0 && product.ListPrice > product.Price)
                                {
                                    <span class="badge px-3 py-1 rounded-pill shadow-sm fw-bold bg-badge-sale" style="font-size: 0.65rem; letter-spacing: 0.5px;">SALE</span>
                                }
                                else
                                {
                                    <span class="badge px-3 py-1 rounded-pill shadow-sm fw-bold bg-badge-new" style="font-size: 0.65rem; letter-spacing: 0.5px;">NEW</span>
                                }
                            </div>
                            
                            @if(string.IsNullOrWhiteSpace(product.ImageUrl))
                            {
                                <div class="w-100 h-100 d-flex justify-content-center align-items-center">
                                    <i class="bi bi-image text-muted text-opacity-25" style="font-size: 4rem;"></i>
                                </div>
                            }
                            else
                            {
                                <img src="/@product.ImageUrl" alt="@product.Title" class="w-100 h-100 product-img" style="object-fit: cover; display: block; mix-blend-mode: multiply; transition: transform 0.3s ease;" />
                            }
                        </div>

                        <!-- Card Body -->
                        <div class="card-body p-4 d-flex flex-column">
                            <p class="text-muted text-uppercase fw-bold mb-1" style="font-size: 0.65rem; letter-spacing: 0.5px;">@product.CategoryName</p>
                            <h6 class="card-title fw-bolder text-dark mb-3" style="font-size: 1.05rem; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden; height: 2.4rem;">@product.Title</h6>
                            
                            <!-- Rating Stars -->
                            <div class="d-flex align-items-center mb-3 mt-auto">
                                <i class="bi bi-star-fill me-1" style="color: var(--accent-coral); font-size: 0.75rem;"></i>
                                <span class="fw-bold text-dark" style="font-size: 0.8rem;">4.8</span>
                                <span class="text-muted ms-1" style="font-size: 0.75rem;">(1248)</span>
                            </div>

                            <div class="pt-2 d-flex justify-content-between align-items-center border-0 mt-2">
                                <div>
                                    <span class="fs-5 fw-bolder text-dark">$@product.Price</span>
                                    @if(product.ListPrice > 0 && product.ListPrice > product.Price)
                                    {
                                        <span class="text-muted text-decoration-line-through small ms-2 fw-semibold" style="font-size: 0.75rem;">$@product.ListPrice</span>
                                    }
                                </div>
                                <a asp-controller="CustomerProduct" asp-action="Details" asp-route-id="@product.Id" class="btn btn-primary d-flex align-items-center justify-content-center p-0 shadow-sm add-cart-btn" style="width: 40px; height: 40px; border-radius: 12px;">
                                    <i class="bi bi-cart3 fs-5"></i>
                                </a>
                            </div>
                        </div>

                    </div>
                </div>
            }
        </div>
    </div>
</div>

<style>
    .category-hover:hover {
        transform: translateY(-5px);
        box-shadow: 0 10px 25px rgba(15, 118, 110, 0.15) !important; /* Teal shadow */
    }
    
    .product-card:hover {
        transform: translateY(-6px);
        box-shadow: 0 15px 30px rgba(0,0,0,0.06) !important;
    }

    .product-card:hover .product-img {
        transform: scale(1.05);
    }
    
    .add-cart-btn:hover {
        background-color: var(--brand-primary-hover) !important;
        transform: scale(1.05);
    }
</style>
