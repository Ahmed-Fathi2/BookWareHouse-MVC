@model BookWarehouse.Application.ViewModels.Product.ProductEditVM

<div class="container-fluid mt-4 mb-5 pb-5 px-md-2">
    <div class="d-flex flex-column flex-md-row justify-content-between align-items-start align-items-md-center mb-4 gap-3">
        <div>
            <h2 class="fw-bold text-primary mb-1"><i class="bi bi-pencil-square me-2"></i>Edit Book</h2>
            <p class="text-muted mb-0">Update the product information for @Model.Title</p>
        </div>
        <a asp-action="Index" class="btn btn-outline-secondary btn-lg shadow-sm">
            <i class="bi bi-arrow-left"></i> Back to List
        </a>
    </div>

    <div class="row">
        <div class="col-12 col-xxl-11 mx-auto">
            <div class="card border border-light shadow-sm mb-4" style="border-radius: 12px; background-color: #ffffff;">
                <div class="card-body p-4 p-md-5">
                    <form method="post" asp-controller="AdminProduct" asp-action="SaveEdit" asp-route-id="@Model.Id" enctype="multipart/form-data">
                        @* <input type="hidden" asp-for="Id" /> *@
                        <input type="hidden" asp-for="ImageUrl" />
                        <div asp-validation-summary="ModelOnly" class="alert alert-danger mb-4 rounded-3 border-0 shadow-sm"></div>

                        <h4 class="section-title"><i class="bi bi-info-circle"></i> Basic Information</h4>
                        


                        <div class="row g-4 mb-5">

                            <div class="col-md-6">
                                <label asp-for="Title" class="form-label"></label>
                                <input asp-for="Title" class="form-control form-control-lg" />
                                <span asp-validation-for="Title" class="text-danger small mt-1 d-block"></span>
                            </div>
                            
                            <div class="col-md-6">
                                <label asp-for="ISBN" class="form-label"></label>
                                <input asp-for="ISBN" class="form-control form-control-lg" />
                                <span asp-validation-for="ISBN" class="text-danger small mt-1 d-block"></span>
                            </div>

                            <div class="col-md-6">
                                <label asp-for="Author" class="form-label"></label>
                                <input asp-for="Author" class="form-control form-control-lg" />
                                <span asp-validation-for="Author" class="text-danger small mt-1 d-block"></span>
                            </div>

                            <div class="col-md-6">
                                <label asp-for="CategoryId" class="form-label"></label>
                                <select class="form-select form-select-lg" asp-for="CategoryId" asp-items="@ViewBag.Categories">
                                    <option disabled>-- Select a Category --</option>
                                </select>
                                <span asp-validation-for="CategoryId" class="text-danger small mt-1 d-block"></span>
                            </div>

                            <div class="col-12">
                                <label asp-for="Description" class="form-label"></label>
                                <textarea asp-for="Description" class="form-control form-control-lg" rows="4"></textarea>
                                <span asp-validation-for="Description" class="text-danger small mt-1 d-block"></span>
                            </div>
                        </div>

                        <h4 class="section-title"><i class="bi bi-tag"></i> Pricing Details</h4>

                        <div class="row g-4 mb-5">
                            <div class="col-md-3">
                                <label asp-for="ListPrice" class="form-label"></label>
                                <div class="input-group">
                                    <span class="input-group-text bg-light border-end-0 text-muted"><i class="bi bi-currency-dollar"></i></span>
                                    <input asp-for="ListPrice" class="form-control form-control-lg border-start-0 ps-0" type="number" step="0.01" />
                                </div>
                                <span asp-validation-for="ListPrice" class="text-danger small mt-1 d-block"></span>
                            </div>

                            <div class="col-md-3">
                                <label asp-for="Price" class="form-label"></label>
                                <div class="input-group">
                                    <span class="input-group-text bg-light border-end-0 text-muted"><i class="bi bi-currency-dollar"></i></span>
                                    <input asp-for="Price" class="form-control form-control-lg border-start-0 ps-0" type="number" step="0.01" />
                                </div>
                                <span asp-validation-for="Price" class="text-danger small mt-1 d-block"></span>
                            </div>

                            <div class="col-md-3">
                                <label asp-for="Price50" class="form-label"></label>
                                <div class="input-group">
                                    <span class="input-group-text bg-light border-end-0 text-muted"><i class="bi bi-currency-dollar"></i></span>
                                    <input asp-for="Price50" class="form-control form-control-lg border-start-0 ps-0" type="number" step="0.01" />
                                </div>
                                <span asp-validation-for="Price50" class="text-danger small mt-1 d-block"></span>
                            </div>

                            <div class="col-md-3">
                                <label asp-for="Price100" class="form-label"></label>
                                <div class="input-group">
                                    <span class="input-group-text bg-light border-end-0 text-muted"><i class="bi bi-currency-dollar"></i></span>
                                    <input asp-for="Price100" class="form-control form-control-lg border-start-0 ps-0" type="number" step="0.01" />
                                </div>
                                <span asp-validation-for="Price100" class="text-danger small mt-1 d-block"></span>
                            </div>
                        </div>
                        <h4 class="section-title"><i class="bi bi-images"></i> Product Media</h4>
                        
                        <div class="row align-items-center mb-5">
                            <div class="col-md-7">
                                <label class="form-label mb-2 fw-semibold">Upload New Product Image If You Want</label>
                                <div class="p-4 border rounded-4 bg-light text-center position-relative" style="border: 2px dashed var(--nvy-border) !important; transition: all 0.3s ease;">
                                    <i class="bi bi-cloud-arrow-up fs-2 text-primary d-block mb-3"></i>
                                    <label for="imageInput" class="btn btn-outline-secondary btn-lg px-4 mb-2 shadow-sm fw-semibold">
                                        Choose New Image...
                                    </label>
                                    <input type="file" name="newImage" id="imageInput" class="d-none" accept="image/*" onchange="previewImage(event)" />
                                    <div class="text-muted small fw-medium" id="fileNameDisplay">Supported formats: JPG, PNG, WEBP. Max 5MB.</div>
                                </div>
                                <span class="text-danger d-block mt-2 fw-medium">@Html.ValidationMessage("Image")</span>
                            </div>

                            <!-- Image Preview Block -->
                            <div class="col-md-5 d-flex flex-column align-items-center justify-content-center mt-4 mt-md-0 position-relative">
                                
                                <div id="previewContainer" class="w-100 d-none">
                                    <div class="bg-light rounded-4 border shadow-sm position-relative overflow-hidden w-100 d-flex justify-content-center align-items-center" style="height: 250px; padding: 0.5rem;">
                                        <img id="imagePreview" src="#" alt="Preview" class="w-100 h-100 rounded-3" style="object-fit: contain; background-color: transparent;" />
                                        <button type="button" class="btn btn-danger position-absolute shadow-lg rounded-circle" onclick="clearImage()" style="top: 10px; right: 10px; width: 32px; height: 32px; padding: 0; display: flex; align-items: center; justify-content: center; z-index: 10;" title="Remove Image">
                                            <i class="bi bi-x fs-5"></i>
                                        </button>
                                    </div>
                                    <p class="mt-2 mb-0 text-center fw-semibold text-success small"><i class="bi bi-check-circle-fill me-1"></i> New Image Preview</p>
                                </div>
                                
                                <div id="noPreviewContainer" class="w-100">
                                    <div class="bg-light rounded-4 border shadow-sm position-relative overflow-hidden w-100 d-flex flex-column justify-content-center align-items-center" style="height: 250px; padding: 0.5rem;">
                                         <img src="~/@Model.ImageUrl" alt="Current Image" class="w-100 h-100 rounded-3" style="object-fit: contain; background-color: transparent;" />
                                    </div>
                                    <p class="mt-2 mb-0 text-center fw-semibold text-muted small"><i class="bi bi-image me-1"></i> Current Image</p>
                                </div>

                            </div>
                        </div>

                        <div class="d-flex align-items-center justify-content-end gap-3 mt-5 pt-4 border-top">
                            <a asp-action="Index" class="btn btn-outline-secondary btn-lg px-4">
                                <i class="bi bi-arrow-left me-2"></i> Cancel
                            </a>
                            <button type="submit" class="btn btn-primary btn-lg px-5 shadow">
                                <i class="bi bi-check-circle-fill me-2"></i> Save Changes
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
    <script>
        function previewImage(event) {
            var input = event.target;
            var container = document.getElementById('previewContainer');
            var noPreview = document.getElementById('noPreviewContainer');
            var output = document.getElementById('imagePreview');
            var fileNameDisplay = document.getElementById('fileNameDisplay');
            
            if (input.files && input.files[0]) {
                // Clear validation message
                var validationSpan = document.querySelector('[data-valmsg-for="Image"]');
                if (validationSpan) {
                    validationSpan.textContent = '';
                }

                fileNameDisplay.textContent = input.files[0].name;
                var reader = new FileReader();
                reader.onload = function(e) {
                    output.src = e.target.result;
                    container.classList.remove('d-none');
                    noPreview.classList.add('d-none');
                }
                reader.readAsDataURL(input.files[0]);
            } else {
                clearImage();
            }
        }

        function clearImage() {
            var input = document.getElementById('imageInput');
            var container = document.getElementById('previewContainer');
            var noPreview = document.getElementById('noPreviewContainer');
            var output = document.getElementById('imagePreview');
            var fileNameDisplay = document.getElementById('fileNameDisplay');
            
            input.value = '';
            fileNameDisplay.textContent = 'Supported formats: JPG, PNG, WEBP. Max 5MB.';
            container.classList.add('d-none');
            noPreview.classList.remove('d-none');
            output.src = '#';
        }
    </script>
}
