@model BookWarehouse.Application.ViewModels.Product.ProductReadDetailsVM

<div class="container-fluid mt-4 mb-5 pb-5 px-md-2">
    <div class="d-flex flex-column flex-md-row justify-content-between align-items-start align-items-md-center mb-4 gap-3">
        <div>
            <div class="d-flex align-items-center gap-3 mb-1">
                <h2 class="fw-bold text-primary mb-0"><i class="bi bi-journal-text me-2"></i>Book Details</h2>
                <span class="badge bg-light text-primary border px-3 py-2 rounded-pill shadow-sm" style="font-size: 0.9rem; font-weight: 600;">@Model.CategoryName</span>
            </div>
            <p class="text-muted mb-0">Comprehensive information and pricing for this product.</p>
        </div>
        <div class="d-flex gap-2">
            <a asp-action="Index" class="btn btn-outline-secondary btn-lg shadow-sm">
                <i class="bi bi-arrow-left"></i> Back to Catalog
            </a>
            <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-primary btn-lg shadow-sm">
                <i class="bi bi-pencil-square"></i> Edit Book
            </a>
        </div>
    </div>

    <div class="row">
        <div class="col-12 col-xxl-11 mx-auto">
            <div class="card border border-light shadow-sm mb-4" style="border-radius: 12px; background-color: #ffffff;">
                <div class="card-body p-4 p-md-5">
                    <div class="row gx-lg-5">
                        
                        <!-- Left Pillar: Image Frame -->
                        <div class="col-md-5 mb-5 mb-md-0">
                            <div class="p-3 bg-light border rounded-4 d-flex justify-content-center align-items-center shadow-sm h-100" style="min-height: 400px; border: 1px solid #e2e8f0 !important;">
                                @if (!string.IsNullOrEmpty(Model.ImageUrl))
                                {
                                    <img src="~/@Model.ImageUrl" alt="@Model.Title" class="img-fluid rounded-3 shadow-sm" style="max-height: 480px; object-fit: contain; background-color: transparent;" />
                                }
                                else
                                {
                                    <div class="text-center text-muted p-5">
                                        <i class="bi bi-image" style="font-size: 6rem; opacity: 0.15;"></i>
                                        <p class="mt-3 fw-semibold fs-5 text-uppercase" style="letter-spacing: 1px;">No Image</p>
                                    </div>
                                }
                            </div>
                        </div>

                        <!-- Right Pillar: Deep Info -->
                        <div class="col-md-7 d-flex flex-column justify-content-center">
                            
                            <h1 class="fw-bold text-dark mb-2" style="font-size: 2.2rem;">@Model.Title</h1>
                            <p class="fs-5 text-muted mb-4 border-bottom pb-3"><i class="bi bi-pen me-2"></i>Written By <strong class="text-dark">@Model.Author</strong></p>

                            <div class="mb-5">
                                <h5 class="fw-bold text-secondary text-uppercase mb-3" style="font-size: 0.85rem; letter-spacing: 1px;"><i class="bi bi-card-text me-2"></i>Description</h5>
                                <div class="text-dark bg-light rounded-4 p-4 border" style="line-height: 1.8; font-size: 1rem;">
                                    @(string.IsNullOrEmpty(Model.Description) ? Html.Raw("<span class='fst-italic text-muted'>No description available for this product.</span>") : Model.Description)
                                </div>
                            </div>

                            <div class="row g-4 mb-5">
                                <div class="col-sm-6">
                                    <div class="bg-light border rounded-4 p-4 shadow-sm h-100">
                                        <div class="text-muted text-uppercase fw-bold mb-2" style="font-size: 0.75rem; letter-spacing: 1px;"><i class="bi bi-upc-scan me-2"></i>ISBN</div>
                                        <div class="fs-5 fw-semibold text-dark">@Model.ISBN</div>
                                    </div>
                                </div>
                                <div class="col-sm-6">
                                    <div class="bg-primary border-0 rounded-4 p-4 shadow-sm h-100 position-relative overflow-hidden">
                                        <!-- Decorative background element -->
                                        <i class="bi bi-tag-fill position-absolute text-white" style="font-size: 6rem; opacity: 0.1; right: -10px; bottom: -20px;"></i>
                                        <div class="text-white-50 text-uppercase fw-bold mb-2 position-relative" style="font-size: 0.75rem; letter-spacing: 1px;"><i class="bi bi-currency-dollar me-1"></i>Standard Price</div>
                                        <div class="d-flex align-items-center gap-3 position-relative">
                                            <span class="text-decoration-line-through text-white-50 fs-6">@Model.ListPrice.ToString("C")</span>
                                            <span class="fw-bold fs-2 text-white">@Model.Price.ToString("C")</span>
                                        </div>
                                    </div>
                                </div>
                            </div>

                            <div class="card border border-light shadow-sm rounded-4 overflow-hidden">
                                <div class="card-header bg-light border-bottom py-3">
                                    <h6 class="mb-0 fw-bold text-secondary text-uppercase" style="font-size: 0.85rem; letter-spacing: 1px;"><i class="bi bi-boxes me-2"></i>Bulk Commercial Discounts</h6>
                                </div>
                                <div class="card-body p-0">
                                    <div class="table-responsive">
                                        <table class="table table-borderless table-hover text-center mb-0 align-middle">
                                            <thead style="background-color: #f8fafc; border-bottom: 1px solid #e2e8f0;">
                                                <tr>
                                                    <th class="py-3 text-muted text-uppercase" style="font-size: 0.75rem; font-weight: 700; letter-spacing: 0.5px;">Quantity</th>
                                                    <th class="py-3 text-dark text-uppercase" style="font-size: 0.75rem; font-weight: 700; letter-spacing: 0.5px;">1 - 50</th>
                                                    <th class="py-3 text-dark text-uppercase" style="font-size: 0.75rem; font-weight: 700; letter-spacing: 0.5px;">51 - 100</th>
                                                    <th class="py-3 text-dark text-uppercase" style="font-size: 0.75rem; font-weight: 700; letter-spacing: 0.5px;">100+</th>
                                                </tr>
                                            </thead>
                                            <tbody>
                                                <tr class="fw-semibold" style="border-bottom: 1px solid #f1f5f9;">
                                                    <td class="text-secondary py-4 bg-light border-end">Unit Price</td>
                                                    <td class="py-4 text-dark fs-5">@Model.Price.ToString("C")</td>
                                                    <td class="text-success py-4 fs-5">@Model.Price50.ToString("C")</td>
                                                    <td class="text-danger py-4 fs-5 fw-bold">@Model.Price100.ToString("C")</td>
                                                </tr>
                                            </tbody>
                                        </table>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
