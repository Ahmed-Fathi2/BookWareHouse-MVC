@* @model IEnumerable<ProductReadVM> *@

<div class="container-fluid mt-5 mb-5 pb-5 px-md-5">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="fw-bold text-primary mb-1"><i class="bi bi-book-half me-2"></i>Books List</h2>
            <p class="text-muted mb-0">Manage your book collection by adding and updating records.</p>
        </div>
        <a asp-action="Create" class="btn btn-primary btn-lg shadow-sm">
            <i class="bi bi-plus-circle-fill"></i> Create New Book
        </a>
    </div>

    <div class="table-container">
        <div class="table-responsive">
            <table id="producttbl" class="table table-bordered table-striped mb-0">
                <thead>
                    <tr>
                        <th>Title</th>
                        <th>ISBN</th>
                        <th>Price</th>
                        <th>Author</th>
                        <th>Category</th>
                        <th class="text-center">Actions</th>  
                    </tr>
                </thead>
               
            </table>
        </div>
    </div>
</div>

@section Scripts{
    <script src="~/js/product.js"></script>
}
