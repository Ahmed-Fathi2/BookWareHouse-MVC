@model IEnumerable<ProductReadVM>


<div class="container py-5 mt-3">
    <!-- Header -->
    <div class="text-center mb-5 pb-3 border-bottom">
        <h2 class="fw-bold text-primary display-5 mb-2"><i class="bi bi-shop-window me-3"></i>Book Store</h2>
        <p class="text-secondary fs-5">Browse and discover your next great read from our latest collection.</p>
    </div>

    <!-- Product Grid -->
    <div class="row">
        @if (!Model.Any())
        {
            <div class="col-12 text-center py-5 my-5">
                <i class="bi bi-bookshelf text-muted text-opacity-50" style="font-size: 5rem;"></i>
                <h3 class="fw-bold text-primary mt-4">We are restocking!</h3>
                <p class="text-secondary fs-5 mt-2">No books are currently available in the warehouse. Please check back later.</p>
            </div>
        }
        else
        {
            foreach (var product in Model)
            {
                <partial name="_ProductCard" model="product" />
            }
        }
    </div>
</div>
