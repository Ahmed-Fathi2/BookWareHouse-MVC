@model CheckoutVM

<style>
    body {
        background-color: #fafafa;
    }

    .checkout-card {
        border-radius: 16px;
        border: 1px solid #f1f3f5;
        background-color: #ffffff;
        padding: 30px;
        box-shadow: 0 4px 15px rgba(0, 0, 0, 0.03);
    }

    .section-title {
        font-weight: 800;
        font-family: 'Inter', sans-serif;
        color: #212529;
        margin-bottom: 30px;
        display: flex;
        align-items: center;
        gap: 10px;
    }

    .form-group-custom {
        margin-bottom: 25px;
    }

    .form-label {
        font-size: 0.8rem;
        font-weight: 700;
        color: #6c757d;
        text-transform: uppercase;
        letter-spacing: 0.5px;
        margin-bottom: 10px;
        display: block;
    }

    .input-with-icon {
        position: relative;
    }

    .input-with-icon i {
        position: absolute;
        left: 18px;
        top: 50%;
        transform: translateY(-50%);
        color: #adb5bd;
        font-size: 1.1rem;
    }

    .input-with-icon .form-control {
        padding-left: 50px;
        padding-right: 20px;
        height: 50px;
        border-radius: 30px;
        border: 1px solid #e9ecef;
        background-color: #fafafa;
        transition: all 0.3s ease;
        box-shadow: none;
    }

    .input-with-icon .form-control:focus {
        background-color: #ffffff;
        border-color: #2563eb;
        box-shadow: 0 0 0 4px rgba(37, 99, 235, 0.1);
    }

    .input-with-icon .form-control::placeholder {
        color: #adb5bd;
    }

    .summary-card {
        border-radius: 16px;
        border: 1px solid #f1f3f5;
        background-color: #ffffff;
        padding: 30px;
        box-shadow: 0 4px 15px rgba(0, 0, 0, 0.03);
    }

    .btn-checkout {
        background: linear-gradient(135deg, #2563eb, #3b82f6);
        color: white;
        border-radius: 30px;
        transition: all 0.3s ease;
        font-weight: 600;
        box-shadow: 0 4px 15px rgba(37, 99, 235, 0.3);
        border: none;
        height: 55px;
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 10px;
    }

    .btn-checkout:hover {
        transform: translateY(-3px);
        box-shadow: 0 6px 20px rgba(37, 99, 235, 0.4);
        color: white;
    }

    .trust-badges {
        display: flex;
        justify-content: center;
        gap: 20px;
        margin-top: 25px;
        color: #6c757d;
        font-size: 0.85rem;
    }
    
    .trust-badge-item {
        display: flex;
        align-items: center;
        gap: 6px;
    }

    hr.dashed {
        border-top: 1px dashed #dee2e6;
        opacity: 1;
        margin: 20px 0;
    }

</style>

<div class="container py-5">
    <div class="row gx-5">
        
        <!-- Left Column: Shipping details -->
        <div class="col-lg-7 mb-5 mb-lg-0">
            <div class="checkout-card">
                <h3 class="section-title">
                    <i class="bi bi-pencil-square text-primary" style="color: #2563eb !important;"></i> 
                    Shipping details
                </h3>

                <form id="checkoutForm" method="post">
                    <input asp-for="OrderTotal" type="hidden" />
                    
                    <div class="form-group-custom">
                        <label asp-for="FullName" class="form-label"></label>
                        <div class="input-with-icon">
                            <i class="bi bi-person"></i>
                            <input asp-for="FullName" class="form-control" placeholder="e.g. Ahmed Hassan" />
                        </div>
                        <span asp-validation-for="FullName" class="text-danger small mt-1 d-block"></span>
                    </div>

                    <div class="form-group-custom">
                        <label asp-for="PhoneNumber" class="form-label"></label>
                        <div class="input-with-icon">
                            <i class="bi bi-telephone"></i>
                            <input asp-for="PhoneNumber" class="form-control" placeholder="+20 123 456 789" />
                        </div>
                        <span asp-validation-for="PhoneNumber" class="text-danger small mt-1 d-block"></span>
                    </div>

                    <div class="form-group-custom">
                        <label asp-for="StreetAddress" class="form-label"></label>
                        <div class="input-with-icon">
                            <i class="bi bi-house"></i>
                            <input asp-for="StreetAddress" class="form-control" placeholder="Building, street, etc." />
                        </div>
                        <span asp-validation-for="StreetAddress" class="text-danger small mt-1 d-block"></span>
                    </div>

                    <div class="form-group-custom">
                        <label asp-for="City" class="form-label"></label>
                        <div class="input-with-icon">
                            <i class="bi bi-building"></i>
                            <input asp-for="City" class="form-control" placeholder="Cairo" />
                        </div>
                        <span asp-validation-for="City" class="text-danger small mt-1 d-block"></span>
                    </div>
                    
                </form>
            </div>
        </div>

        <!-- Right Column: Order Summary -->
        <div class="col-lg-5">
            <div class="summary-card sticky-top" style="top: 2rem;">
                <h4 class="section-title" style="margin-bottom: 20px;">
                    <i class="bi bi-receipt text-primary" style="color: #2563eb !important;"></i> 
                    Order summary
                </h4>
                
                <hr class="dashed">
                
                <div class="d-flex justify-content-between mb-3">
                    <span class="text-muted fs-6">Subtotal</span>
                    <span class="text-dark fw-bold fs-6">@Model.OrderTotal.ToString("c")</span>
                </div>
                
                <div class="d-flex justify-content-between mb-3">
                    <span class="text-muted fs-6">Shipping</span>
                    <span class="fw-bold fs-6" style="color: #2563eb;">Free</span>
                </div>

                <hr class="dashed">

                <div class="d-flex justify-content-between align-items-center mb-4 mt-2">
                    <h4 class="fw-bold text-dark mb-0">Total</h4>
                    <h3 class="fw-bold mb-0" style="color: #2563eb;">@Model.OrderTotal.ToString("c")</h3>
                </div>

                <button type="submit" form="checkoutForm" class="btn btn-checkout btn-lg w-100 mt-2">
                    <i class="bi bi-lock-fill"></i> Secure checkout
                </button>
                
                <div class="trust-badges">
                    <div class="trust-badge-item">
                        <i class="bi bi-shield-check"></i> SSL
                    </div>
                    <div class="trust-badge-item">
                        <i class="bi bi-credit-card"></i> PCI
                    </div>
                    <div class="trust-badge-item">
                        <i class="bi bi-clock-history"></i> 30-day returns
                    </div>
                </div>
            </div>
        </div>

    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
