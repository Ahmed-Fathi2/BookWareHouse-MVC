@model ShoppingCartVM

@{
    ViewData["Title"] = "Payment Successful";
    int orderId = ViewBag.OrderId ?? 0;
}

<div class="container py-5" style="min-height: 80vh; display: flex; align-items: center; justify-content: center;">
    <div class="card shadow-lg p-5 rounded-4 border-0" style="max-width: 600px; width: 100%; background: #ffffff;">
        <div class="text-center mb-4">
            <div class="rounded-circle bg-success bg-opacity-10 d-inline-flex align-items-center justify-content-center mb-3" style="width: 100px; height: 100px;">
                <i class="bi bi-check-circle-fill text-success" style="font-size: 3.5rem;"></i>
            </div>
            <h2 class="fw-bold mb-2" style="color: #2b2b2b;">Payment Successful!</h2>
            <p class="text-muted fs-5">Thank you for your purchase.</p>
        </div>

        <div class="bg-light rounded-3 p-4 mb-4">
            <h5 class="fw-bold text-dark mb-3">Order #@orderId</h5>
            
            <div class="d-flex flex-column gap-2 mb-3 border-bottom pb-3">
                @foreach(var item in Model.CartList)
                {
                    <div class="d-flex justify-content-between align-items-center">
                        <span class="text-secondary">@item.Title <span class="fw-bold text-dark ms-1">x @item.Count</span></span>
                        <span class="text-dark fw-medium">@item.FinalPrice.ToString("c")</span>
                    </div>
                }
            </div>

            <div class="d-flex justify-content-between align-items-center">
                <span class="fs-5 fw-bold text-dark">Total:</span>
                <span class="fs-4 fw-bold text-success">@Model.OrderTotal.ToString("c")</span>
            </div>
        </div>

        <div class="text-center">
            <a asp-controller="CustomerProduct" asp-action="Index" class="btn btn-primary btn-lg rounded-pill px-5 fw-bold shadow-sm hover-lift" style="transition: transform 0.3s ease, box-shadow 0.3s ease;">
                <i class="bi bi-arrow-left me-2"></i> Continue Shopping
            </a>
        </div>
    </div>
</div>

<style>
    body {
        background-color: #f8f9fa;
    }
    .hover-lift:hover {
        transform: translateY(-3px);
        box-shadow: 0 10px 20px rgba(0, 0, 0, 0.15) !important;
    }
</style>
