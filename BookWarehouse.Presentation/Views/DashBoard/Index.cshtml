@model BookWarehouse.Application.ViewModels.DashBoard.DashboardStatsVM
@{
    ViewData["Title"] = "Dashboard";
}

<div class="dashboard-header d-flex flex-column flex-md-row justify-content-between align-items-start align-items-md-center gap-3">
    <div>
        <h1 class="dashboard-title">Welcome back, Admin 👋</h1>
        <p class="dashboard-subtitle">Here's what's happening with your store today.</p>
    </div>
    <div>
        <a asp-controller="Order" asp-action="Index" class="btn btn-primary px-4 py-2 rounded-3 shadow-sm">
            View all orders <i class="bi bi-arrow-up-right ms-1"></i>
        </a>
    </div>
</div>

<div class="stats-grid">
    <div class="stat-card">
        <div class="stat-icon icon-revenue">
            <i class="bi bi-currency-dollar"></i>
        </div>
        <div class="stat-label">Total Revenue</div>
        <div class="stat-value">@Model.TotalRevenue.ToString("C")</div>
        <div class="stat-trend">
            <span class="text-primary fw-bold">@Model.MonthlyRevenue.ToString("C")</span>
            <span class="text-muted ms-1">this month</span>
        </div>
    </div>

    <div class="stat-card">
        <div class="stat-icon icon-orders">
            <i class="bi bi-cart-check"></i>
        </div>
        <div class="stat-label">Total Orders</div>
        <div class="stat-value">@Model.TotalOrders</div>
        <div class="stat-trend">
            <span class="text-success fw-bold">@Model.ApprovedOrders</span>
            <span class="text-muted ms-1">approved</span>
        </div>
    </div>

    <div class="stat-card">
        <div class="stat-icon icon-customers">
            <i class="bi bi-people"></i>
        </div>
        <div class="stat-label">Total Customers</div>
        <div class="stat-value">@Model.TotalCustomers</div>
        <div class="stat-trend">
            <span class="text-info fw-bold">@Model.TotalProducts</span>
            <span class="text-muted ms-1">total products</span>
        </div>
    </div>

    <div class="stat-card">
        <div class="stat-icon icon-products">
            <i class="bi bi-clock-history"></i>
        </div>
        <div class="stat-label">Pending Orders</div>
        <div class="stat-value">@Model.PendingOrders</div>
        <div class="stat-trend">
            <span class="text-warning fw-bold">@Model.TodayRevenue.ToString("C")</span>
            <span class="text-muted ms-1">revenue today</span>
        </div>
    </div>
</div>

<div class="dashboard-grid">
    <!-- Revenue Summary -->
    <div class="card">
        <div class="card-header">
            <h3 class="card-title">Revenue Summary</h3>
            <span class="badge bg-light text-primary rounded-pill px-3">
                <i class="bi bi-calendar3 me-1"></i> Current Period
            </span>
        </div>
        <div class="text-muted small mb-4">Detailed financial breakdown</div>
        
        <div class="d-flex flex-column gap-4 py-3">
            <div class="d-flex align-items-center justify-content-between p-3 rounded-4 bg-light">
                <div class="d-flex align-items-center gap-3">
                    <div class="rounded-circle bg-white shadow-sm d-flex align-items-center justify-content-center" style="width: 45px; height: 45px;">
                        <i class="bi bi-lightning-fill text-warning"></i>
                    </div>
                    <div>
                        <div class="text-muted small fw-bold text-uppercase">Today's Sales</div>
                        <div class="fs-4 fw-bolder text-dark">@Model.TodayRevenue.ToString("C")</div>
                    </div>
                </div>
                <i class="bi bi-chevron-right text-muted"></i>
            </div>

            <div class="d-flex align-items-center justify-content-between p-3 rounded-4 bg-light">
                <div class="d-flex align-items-center gap-3">
                    <div class="rounded-circle bg-white shadow-sm d-flex align-items-center justify-content-center" style="width: 45px; height: 45px;">
                        <i class="bi bi-calendar-check-fill text-primary"></i>
                    </div>
                    <div>
                        <div class="text-muted small fw-bold text-uppercase">Monthly Performance</div>
                        <div class="fs-4 fw-bolder text-dark">@Model.MonthlyRevenue.ToString("C")</div>
                    </div>
                </div>
                <i class="bi bi-chevron-right text-muted"></i>
            </div>

            <div class="d-flex align-items-center justify-content-between p-3 rounded-4 bg-light">
                <div class="d-flex align-items-center gap-3">
                    <div class="rounded-circle bg-white shadow-sm d-flex align-items-center justify-content-center" style="width: 45px; height: 45px;">
                        <i class="bi bi-wallet-fill text-success"></i>
                    </div>
                    <div>
                        <div class="text-muted small fw-bold text-uppercase">Total Lifetime Revenue</div>
                        <div class="fs-4 fw-bolder text-dark">@Model.TotalRevenue.ToString("C")</div>
                    </div>
                </div>
                <i class="bi bi-chevron-right text-muted"></i>
            </div>
        </div>
    </div>

    <!-- Order Status -->
    <div class="card">
        <div class="card-header">
            <h3 class="card-title">Order Status</h3>
        </div>
        <div class="text-muted small mb-4">Live distribution of all orders</div>
        
        <div class="status-list">
            <div class="status-item">
                <div class="status-icon" style="background: #fff7ed; color: #f59e0b;">
                    <i class="bi bi-clock"></i>
                </div>
                <div class="status-info">
                    <div class="d-flex justify-content-between">
                        <span class="status-name">Pending</span>
                        <span class="status-count">@Model.PendingOrders (@(Model.TotalOrders > 0 ? (Model.PendingOrders * 100 / Model.TotalOrders) : 0)%)</span>
                    </div>
                    <div class="status-progress">
                        <div class="progress-bar" style="width: @(Model.TotalOrders > 0 ? (Model.PendingOrders * 100 / Model.TotalOrders) : 0)%; background: #f59e0b;"></div>
                    </div>
                </div>
            </div>

            <div class="status-item">
                <div class="status-icon" style="background: #eff6ff; color: #3b82f6;">
                    <i class="bi bi-gear"></i>
                </div>
                <div class="status-info">
                    <div class="d-flex justify-content-between">
                        <span class="status-name">Processing</span>
                        <span class="status-count">@Model.ProcessingOrders (@(Model.TotalOrders > 0 ? (Model.ProcessingOrders * 100 / Model.TotalOrders) : 0)%)</span>
                    </div>
                    <div class="status-progress">
                        <div class="progress-bar" style="width: @(Model.TotalOrders > 0 ? (Model.ProcessingOrders * 100 / Model.TotalOrders) : 0)%; background: #3b82f6;"></div>
                    </div>
                </div>
            </div>

            <div class="status-item">
                <div class="status-icon" style="background: #f5f3ff; color: #8b5cf6;">
                    <i class="bi bi-truck"></i>
                </div>
                <div class="status-info">
                    <div class="d-flex justify-content-between">
                        <span class="status-name">Shipped</span>
                        <span class="status-count">@Model.ShippedOrders (@(Model.TotalOrders > 0 ? (Model.ShippedOrders * 100 / Model.TotalOrders) : 0)%)</span>
                    </div>
                    <div class="status-progress">
                        <div class="progress-bar" style="width: @(Model.TotalOrders > 0 ? (Model.ShippedOrders * 100 / Model.TotalOrders) : 0)%; background: #8b5cf6;"></div>
                    </div>
                </div>
            </div>

            <div class="status-item">
                <div class="status-icon" style="background: #ecfdf5; color: #10b981;">
                    <i class="bi bi-check2-circle"></i>
                </div>
                <div class="status-info">
                    <div class="d-flex justify-content-between">
                        <span class="status-name">Delivered</span>
                        <span class="status-count">@Model.DeliveredOrders (@(Model.TotalOrders > 0 ? (Model.DeliveredOrders * 100 / Model.TotalOrders) : 0)%)</span>
                    </div>
                    <div class="status-progress">
                        <div class="progress-bar" style="width: @(Model.TotalOrders > 0 ? (Model.DeliveredOrders * 100 / Model.TotalOrders) : 0)%; background: #10b981;"></div>
                    </div>
                </div>
            </div>

            <div class="status-item mt-2 pt-2 border-top">
                <div class="status-icon" style="background: #fef2f2; color: #ef4444;">
                    <i class="bi bi-x-circle"></i>
                </div>
                <div class="status-info">
                    <div class="d-flex justify-content-between">
                        <span class="status-name">Cancelled</span>
                        <span class="status-count">@Model.CancelledOrders</span>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
