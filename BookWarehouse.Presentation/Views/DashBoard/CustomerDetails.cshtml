@* @model IEnumerable<ProductReadVM> *@

<div class="container-fluid mt-4 mb-5 pb-5 px-md-2">
    <div class="d-flex flex-column flex-md-row justify-content-between align-items-start align-items-md-center mb-4 gap-3">
        <div>
            <h2 class="fw-bold text-primary mb-1"><i class="bi bi-people-fill me-2"></i>Customers List</h2>
            <p class="text-muted mb-0">View and manage your registered customers and their order activity.</p>
        </div>
        @* <a asp-action="Create" class="btn btn-primary btn-lg shadow-sm">
            <i class="bi bi-plus-circle-fill"></i> Create New Boo
        </a> *@
    </div>

    <div class="card border border-light shadow-sm overflow-hidden" style="border-radius: 12px; background-color: #ffffff;">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table id="customersTable" class="table align-middle mb-0 w-100 border-0">
                    <thead style="background-color: #f8fafc; border-bottom: 1px solid #e2e8f0;">
                            <th class="py-3 px-4 text-uppercase border-0" style="font-size: 0.75rem; color: #64748b; font-weight: 700; letter-spacing: 0.5px;">Customer Name</th>
                            <th class="py-3 text-uppercase border-0" style="font-size: 0.75rem; color: #64748b; font-weight: 700; letter-spacing: 0.5px;">Email</th>
                            <th class="py-3 text-center text-uppercase border-0" style="font-size: 0.75rem; color: #64748b; font-weight: 700; letter-spacing: 0.5px;">Orders Count</th>
                    </thead>
                    <tbody style="transition: opacity 0.3s ease-in-out;">
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="~/js/customers.js"></script>
}
