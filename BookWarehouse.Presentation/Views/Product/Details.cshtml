@model ProductReadDetailsVM

<div class="card form-card shadow border-0 mt-4 mb-5">
    <div class="card-header bg-secondary bg-gradient py-3">
        <div class="row">
            <div class="col-12 text-center">
                <h2 class="text-white py-2">Product Details</h2>
            </div>
        </div>
    </div>
    <div class="card-body">
        <div class="row mb-4">
            <div class="col-md-3 d-flex align-items-center">
                <label asp-for="Title" class="col-form-label form-label-custom"></label>
            </div>
            <div class="col-md-9">
                <input asp-for="Title" class="form-control form-control-custom" readonly />
            </div>
        </div>

        <div class="row mb-4">
            <div class="col-md-3 d-flex align-items-center">
                <label asp-for="Description" class="col-form-label form-label-custom"></label>
            </div>
            <div class="col-md-9">
                <input asp-for="Description" class="form-control form-control-custom" readonly />
            </div>
        </div>

        <div class="row mb-4">
            <div class="col-md-3 d-flex align-items-center">
                <label asp-for="ISBN" class="col-form-label form-label-custom"></label>
            </div>
            <div class="col-md-9">
                <input asp-for="ISBN" class="form-control form-control-custom" readonly />
            </div>
        </div>

        <div class="row mb-4">
            <div class="col-md-3 d-flex align-items-center">
                <label asp-for="Author" class="col-form-label form-label-custom"></label>
            </div>
            <div class="col-md-9">
                <input asp-for="Author" class="form-control form-control-custom" readonly />
            </div>
        </div>

        <div class="row mb-4">
            <div class="col-md-3 d-flex align-items-center">
                <label asp-for="ListPrice" class="col-form-label form-label-custom"></label>
            </div>
            <div class="col-md-9">
                <input asp-for="ListPrice" class="form-control form-control-custom" readonly />
            </div>
        </div>

        <div class="row mb-4">
            <div class="col-md-3 d-flex align-items-center">
                <label asp-for="Price" class="col-form-label form-label-custom"></label>
            </div>
            <div class="col-md-9">
                <input asp-for="Price" class="form-control form-control-custom" readonly />
            </div>
        </div>

        <div class="row mb-4">
            <div class="col-md-3 d-flex align-items-center">
                <label asp-for="Price50" class="col-form-label form-label-custom"></label>
            </div>
            <div class="col-md-9">
                <input asp-for="Price50" class="form-control form-control-custom" readonly />
            </div>
        </div>

        <div class="row mb-4">
            <div class="col-md-3 d-flex align-items-center">
                <label asp-for="Price100" class="col-form-label form-label-custom"></label>
            </div>
            <div class="col-md-9">
                <input asp-for="Price100" class="form-control form-control-custom" readonly />
            </div>
        </div>

        <div class="row mb-4">
            <div class="col-md-3 d-flex align-items-center">
                <label asp-for="CategoryName" class="col-form-label form-label-custom"></label>
            </div>
            <div class="col-md-9">
                <input asp-for="CategoryName" class="form-control form-control-custom" readonly />
            </div>
        </div>

        <div class="d-flex gap-2">
            <a asp-action="Index" class="btn btn-outline-secondary">Back to List</a>
        </div>
    </div>
</div>
