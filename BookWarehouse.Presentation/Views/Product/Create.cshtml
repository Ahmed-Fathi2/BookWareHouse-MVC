@model ProductCreateVM


<div class="card form-card shadow border-0 mt-4">
    <div class="card-header bg-secondary bg-gradient py-3">
        <div class="row">
            <div class="col-12 text-center">
                <h2 class="text-white py-2">Create Product</h2>
            </div>
        </div>
    </div>
    <div class="card-body">
        <form method="post" asp-controller="Product" asp-action="SaveCreate">
            <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

            <div class="row form-section">
                <div class="col-md-3 d-flex align-items-center">
                    <label asp-for="Title" class="col-form-label form-label-custom"></label>
                </div>
                <div class="col-md-9">
                    <input asp-for="Title" class="form-control form-control-custom" />
                    <span asp-validation-for="Title" class="text-danger"></span>
                </div>
            </div>

            <div class="row form-section">
                <div class="col-md-3 d-flex align-items-center">
                    <label asp-for="Description" class="col-form-label form-label-custom"></label>
                </div>
                <div class="col-md-9">
                    <input asp-for="Description" class="form-control form-control-custom" />
                    <span asp-validation-for="Description" class="text-danger"></span>
                </div>
            </div>

            <div class="row form-section">
                <div class="col-md-3 d-flex align-items-center">
                    <label asp-for="ISBN" class="col-form-label form-label-custom"></label>
                </div>
                <div class="col-md-9">
                    <input asp-for="ISBN" class="form-control form-control-custom" />
                    <span asp-validation-for="ISBN" class="text-danger"></span>
                </div>
            </div>

            <div class="row form-section">
                <div class="col-md-3 d-flex align-items-center">
                    <label asp-for="Author" class="col-form-label form-label-custom"></label>
                </div>
                <div class="col-md-9">
                    <input asp-for="Author" class="form-control form-control-custom" />
                    <span asp-validation-for="Author" class="text-danger"></span>
                </div>
            </div>

            <div class="form-divider"></div>

            <div class="row form-section">
                <div class="col-md-3 d-flex align-items-center">
                    <label asp-for="ListPrice" class="col-form-label form-label-custom"></label>
                </div>
                <div class="col-md-3">
                    <input asp-for="ListPrice" class="form-control" type="number" step="0.01" />
                    <span asp-validation-for="ListPrice" class="text-danger"></span>
                </div>

                <div class="col-md-3 d-flex align-items-center">
                    <label asp-for="Price" class="col-form-label form-label-custom"></label>
                </div>
                <div class="col-md-3">
                    <input asp-for="Price" class="form-control" type="number" step="0.01" />
                    <span asp-validation-for="Price" class="text-danger"></span>
                </div>
            </div>

            <div class="row form-section">
                <div class="col-md-3 d-flex align-items-center">
                    <label asp-for="Price50" class="col-form-label form-label-custom"></label>
                </div>
                <div class="col-md-3">
                    <input asp-for="Price50" class="form-control" type="number" step="0.01" />
                    <span asp-validation-for="Price50" class="text-danger"></span>
                </div>

                <div class="col-md-3 d-flex align-items-center">
                    <label asp-for="Price100" class="col-form-label form-label-custom"></label>
                </div>
                <div class="col-md-3">
                    <input asp-for="Price100" class="form-control" type="number" step="0.01" />
                    <span asp-validation-for="Price100" class="text-danger"></span>
                </div>
            </div>

            <div class="row form-section">
                <div class="col-md-3 d-flex align-items-center">
                    <label asp-for="CategoryId" class="col-form-label form-label-custom"></label>
                </div>
                <div class="col-md-9">
                    <select class="form-select form-control-custom" asp-for="CategoryId" asp-items="@ViewBag.Categories">
                        <option disabled selected>--Select Category--</option>

                    </select>
                    <span asp-validation-for="CategoryId" class="text-danger"></span>
                </div>
            </div>

            <div class="form-actions">
                <a asp-action="Index" class="btn btn-outline-secondary"><i class="bi bi-arrow-left"></i> Cancel</a>
                <button type="submit" class="btn btn-primary"><i class="bi bi-plus-circle"></i> Create</button>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
