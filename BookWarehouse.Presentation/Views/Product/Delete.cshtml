@model BookWarehouse.Application.ViewModels.Product.ProductEditVM

<div class="card form-card shadow border-0 mt-4 mb-5">
    <div class="card-header bg-secondary bg-gradient ml-0 py-3">
        <div class="row">
            <div class="col-12 text-center">
                <h2 class="text-white py-2">Delete Product</h2>
            </div>
        </div>
    </div>
    <div class="card-body">
        <form method="post" asp-controller="Product" asp-action="SaveDelete" asp-route-id="@Model.Id">
            <div class="row form-section">
            <div class="col-md-3 d-flex align-items-center">
                    <label asp-for="Title" class="col-form-label form-label-custom"></label>
                </div>
                <div class="col-md-9">
                    <input asp-for="Title" disabled class="form-control form-control-custom" />
                </div>
            </div>

            <div class="row form-section">
                <div class="col-md-3 d-flex align-items-center">
                    <label asp-for="Description" class="col-form-label form-label-custom"></label>
                </div>
                <div class="col-md-9">
                    <input asp-for="Description" disabled class="form-control form-control-custom" />
                </div>
            </div>

            <div class="row form-section">
                <div class="col-md-3 d-flex align-items-center">
                    <label asp-for="ISBN" class="col-form-label form-label-custom"></label>
                </div>
                <div class="col-md-9">
                    <input asp-for="ISBN" disabled class="form-control form-control-custom" />
                </div>
            </div>

            <div class="row form-section">
                <div class="col-md-3 d-flex align-items-center">
                    <label asp-for="Author" class="col-form-label form-label-custom"></label>
                </div>
                <div class="col-md-9">
                    <input asp-for="Author" disabled class="form-control form-control-custom" />
                </div>
            </div>

            <div class="row form-section">
                <div class="col-md-3 d-flex align-items-center">
                    <label asp-for="ListPrice" class="col-form-label form-label-custom"></label>
                </div>
                <div class="col-md-9">
                    <input asp-for="ListPrice" disabled class="form-control form-control-custom" />
                </div>
            </div>

            <div class="row form-section">
                <div class="col-md-3 d-flex align-items-center">
                    <label asp-for="Price" class="col-form-label form-label-custom"></label>
                </div>
                <div class="col-md-9">
                    <input asp-for="Price" disabled class="form-control form-control-custom" />
                </div>
            </div>

            <div class="row form-section">
                <div class="col-md-3 d-flex align-items-center">
                    <label asp-for="Price50" class="col-form-label form-label-custom"></label>
                </div>
                <div class="col-md-9">
                    <input asp-for="Price50" disabled class="form-control form-control-custom" />
                </div>
            </div>

            <div class="row form-section">
                <div class="col-md-3 d-flex align-items-center">
                    <label asp-for="Price100" class="col-form-label form-label-custom"></label>
                </div>
                <div class="col-md-9">
                    <input asp-for="Price100" disabled class="form-control form-control-custom" />
                </div>
            </div>

             <div class="row form-section">
                <div class="col-md-3 d-flex align-items-center">
                  
                    <label class="col-form-label form-label-custom">Category Name</label>
                </div>
                <div class="col-md-9">
                    <input type="text" value="@ViewBag.CategoryName" disabled class="form-control form-control-custom" />
                </div>
            </div> 

            <div class="form-actions">
                <a asp-action="Index" class="btn btn-outline-secondary"><i class="bi bi-arrow-left"></i> Cancel</a>
                <button type="submit" class="btn btn-danger"><i class="bi bi-trash-fill"></i> Delete</button>
            </div>
        </form>
    </div>
</div>
