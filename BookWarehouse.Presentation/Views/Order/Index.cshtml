
<div class="container-fluid mt-5 mb-5 pb-5 px-md-5">
    <div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center mb-4 gap-3">
        <div>
            <h2 class="fw-bold text-primary mb-1"><i class="bi bi-inboxes me-2"></i>Orders Management</h2>
            <p class="text-muted mb-0">View, filter, and manage customer orders.</p>
        </div>
        
        <div class="d-flex align-items-center">
            <div class="dropdown custom-filter-dropdown">
                <button class="btn rounded-pill d-flex align-items-center gap-2 px-4 py-2 fw-bold text-white shadow-sm border-0 dropdown-toggle" type="button" id="statusFilterDropdown" data-bs-toggle="dropdown" aria-expanded="false" style="background: linear-gradient(135deg, #4f46e5, #7c3aed); transition: all 0.3s ease;">
                    <i class="bi bi-funnel-fill"></i>
                    <span id="currentFilterText">All Orders</span>
                    <i class="bi bi-chevron-down ms-2" style="font-size: 0.8rem; transition: transform 0.3s ease;" id="dropdownChevron"></i>
                </button>
                <ul class="dropdown-menu dropdown-menu-end shadow-lg border-0 rounded-4 mt-2 p-2 animated-dropdown" aria-labelledby="statusFilterDropdown" style="min-width: 220px;">
                    <li><a class="dropdown-item rounded-3 mb-1 filter-dropdown-btn active" href="#" data-status="all"><i class="bi bi-list-ul text-primary me-3"></i>All Orders</a></li>
                    <li><a class="dropdown-item rounded-3 mb-1 filter-dropdown-btn" href="#" data-status="Pending"><i class="bi bi-hourglass-split text-secondary me-3"></i>Pending</a></li>
                    <li><a class="dropdown-item rounded-3 mb-1 filter-dropdown-btn" href="#" data-status="Approved"><i class="bi bi-check-circle-fill text-success me-3"></i>Approved</a></li>
                    <li><a class="dropdown-item rounded-3 mb-1 filter-dropdown-btn" href="#" data-status="Processing"><i class="bi bi-gear-fill text-warning me-3"></i>Processing</a></li>
                    <li><a class="dropdown-item rounded-3 mb-1 filter-dropdown-btn" href="#" data-status="Shipped"><i class="bi bi-truck text-info me-3"></i>Shipped</a></li>
                    <li><a class="dropdown-item rounded-3 mb-1 filter-dropdown-btn" href="#" data-status="Delivered"><i class="bi bi-box-seam-fill text-success me-3"></i>Delivered</a></li>
                    <li><hr class="dropdown-divider my-1"></li>
                    <li><a class="dropdown-item rounded-3 filter-dropdown-btn text-danger fw-bold" href="#" data-status="Cancelled"><i class="bi bi-x-circle-fill me-3"></i>Cancelled</a></li>
                </ul>
            </div>
        </div>
    </div>

    <div class="card border-0 shadow-sm rounded-4 overflow-hidden">
        <div class="card-body p-4">
            <div class="table-responsive">
                <table id="orderTable" class="table table-hover table-striped table-bordered align-middle mb-0 w-100">
                    <thead class="bg-light">
                        <tr>
                            <th class="py-3 text-uppercase" style="font-size: 0.85rem; color: #000 !important; font-weight: 900 !important;">Order ID</th>
                            <th class="py-3 text-uppercase" style="font-size: 0.85rem; color: #000 !important; font-weight: 900 !important;">Customer Name</th>
                            <th class="py-3 text-uppercase" style="font-size: 0.85rem; color: #000 !important; font-weight: 900 !important;">Phone</th>
                            <th class="py-3 text-uppercase" style="font-size: 0.85rem; color: #000 !important; font-weight: 900 !important;">Order Date</th>
                            <th class="py-3 text-center text-uppercase" style="font-size: 0.85rem; color: #000 !important; font-weight: 900 !important;">Order Status</th>
                            <th class="py-3 text-center text-uppercase" style="font-size: 0.85rem; color: #000 !important; font-weight: 900 !important;">Payment Status</th>
                            <th class="py-3 text-center text-uppercase" style="font-size: 0.85rem; color: #000 !important; font-weight: 900 !important;">Actions</th>
                        </tr>
                    </thead>
                    <tbody class="border-top-0" style="transition: opacity 0.3s ease-in-out;">
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="~/js/order.js"></script>
    <style>
        .custom-filter-dropdown {
            z-index: 1050;
        }
        .custom-filter-dropdown .btn:hover {
            transform: translateY(-2px);
            box-shadow: 0 8px 15px rgba(79, 70, 229, 0.3) !important;
        }
        .custom-filter-dropdown .dropdown-toggle::after {
            display: none;
        }
        .custom-filter-dropdown.show #dropdownChevron {
            transform: rotate(180deg);
        }
        .animated-dropdown {
            animation: fadeInDropdown 0.2s cubic-bezier(0.4, 0, 0.2, 1) forwards;
            transform-origin: top right;
        }
        @@keyframes fadeInDropdown {
            from { opacity: 0; transform: scale(0.95) translateY(-5px); }
            to { opacity: 1; transform: scale(1) translateY(0); }
        }
        .filter-dropdown-btn {
            font-weight: 600;
            color: #4b5563;
            transition: all 0.2s ease;
            padding: 10px 16px;
        }
        .filter-dropdown-btn:hover {
            background-color: #f3f4f6;
            color: #111827;
            transform: translateX(4px);
        }
        .filter-dropdown-btn.active {
            background-color: #eef2ff;
            color: #4f46e5;
            box-shadow: inset 3px 0 0 #4f46e5;
        }
        
        table.dataTable tbody tr td {
            vertical-align: middle;
            border-bottom: 1px solid #f1f5f9;
        }
        .table-hover tbody tr:hover td {
            background-color: #f8fafc;
        }
    </style>
}
