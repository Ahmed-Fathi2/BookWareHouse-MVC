@model IEnumerable<OrderDetailsVM>
@{
    bool isAdmin = User.IsInRole("Admin") || User.IsInRole("SuperAdmin");
    ViewData["Title"] = isAdmin ? "Orders Management" : "My Orders";
}

@if (isAdmin)
{
    @* --- ADMIN DASHBOARD UI (Do NOT Touch) --- *@
    <div class="container-fluid mt-4 mb-5 pb-5 px-md-2">
        <div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center mb-4 gap-3">
            <div>
                <h2 class="fw-bold text-primary mb-1"><i class="bi bi-inboxes me-2"></i>Orders Management</h2>
                <p class="text-muted mb-0">View, filter, and manage customer orders.</p>
            </div>
            
            <div class="d-flex align-items-center">
                <div class="dropdown custom-filter-dropdown">
                    <button class="btn rounded-pill d-flex align-items-center gap-2 px-4 py-2 fw-bold text-white shadow-sm border-0 dropdown-toggle" type="button" id="statusFilterDropdown" data-bs-toggle="dropdown" aria-expanded="false" style="background: linear-gradient(135deg, #4f46e5, #7c3aed); transition: all 0.3s ease;">
                        <i class="bi bi-funnel-fill"></i>
                        <span id="currentFilterText">All Orders</span>
                        <i class="bi bi-chevron-down ms-2" style="font-size: 0.8rem; transition: transform 0.3s ease;" id="dropdownChevron"></i>
                    </button>
                    <ul class="dropdown-menu dropdown-menu-end shadow-lg border-0 rounded-4 mt-2 p-2 animated-dropdown" aria-labelledby="statusFilterDropdown" style="min-width: 220px;">
                        <li><a class="dropdown-item rounded-3 mb-1 filter-dropdown-btn active" href="#" data-status="all"><i class="bi bi-list-ul text-primary me-3"></i>All Orders</a></li>
                        <li><a class="dropdown-item rounded-3 mb-1 filter-dropdown-btn" href="#" data-status="Pending"><i class="bi bi-hourglass-split text-secondary me-3"></i>Pending</a></li>
                        <li><a class="dropdown-item rounded-3 mb-1 filter-dropdown-btn" href="#" data-status="Approved"><i class="bi bi-check-circle-fill text-success me-3"></i>Approved</a></li>
                        <li><a class="dropdown-item rounded-3 mb-1 filter-dropdown-btn" href="#" data-status="Processing"><i class="bi bi-gear-fill text-warning me-3"></i>Processing</a></li>
                        <li><a class="dropdown-item rounded-3 mb-1 filter-dropdown-btn" href="#" data-status="Shipped"><i class="bi bi-truck text-info me-3"></i>Shipped</a></li>
                        <li><a class="dropdown-item rounded-3 mb-1 filter-dropdown-btn" href="#" data-status="Delivered"><i class="bi bi-box-seam-fill text-success me-3"></i>Delivered</a></li>
                        <li><hr class="dropdown-divider my-1"></li>
                        <li><a class="dropdown-item rounded-3 filter-dropdown-btn text-danger fw-bold" href="#" data-status="Cancelled"><i class="bi bi-x-circle-fill me-3"></i>Cancelled</a></li>
                    </ul>
                </div>
            </div>
        </div>

        <div class="card border border-light shadow-sm overflow-hidden" style="border-radius: 12px; background-color: #ffffff;">
            <div class="card-body p-0">
                <div class="table-responsive">
                    <table id="orderTable" class="table align-middle mb-0 w-100 border-0">
                        <thead style="background-color: #f8fafc; border-bottom: 1px solid #e2e8f0;">
                            <tr>
                                <th class="py-3 px-4 text-uppercase border-0" style="font-size: 0.75rem; color: #64748b; font-weight: 700; letter-spacing: 0.5px;">Order</th>
                                <th class="py-3 text-uppercase border-0" style="font-size: 0.75rem; color: #64748b; font-weight: 700; letter-spacing: 0.5px;">Customer</th>
                                <th class="py-3 text-uppercase border-0" style="font-size: 0.75rem; color: #64748b; font-weight: 700; letter-spacing: 0.5px;">Contact</th>
                                <th class="py-3 text-uppercase border-0" style="font-size: 0.75rem; color: #64748b; font-weight: 700; letter-spacing: 0.5px;">Date</th>
                                <th class="py-3 text-uppercase border-0" style="font-size: 0.75rem; color: #64748b; font-weight: 700; letter-spacing: 0.5px;">Items</th>
                                <th class="py-3 text-uppercase border-0" style="font-size: 0.75rem; color: #64748b; font-weight: 700; letter-spacing: 0.5px;">Total</th>
                                <th class="py-3 text-center text-uppercase border-0" style="font-size: 0.75rem; color: #64748b; font-weight: 700; letter-spacing: 0.5px;">Status</th>
                                <th class="py-3 text-center text-uppercase border-0" style="font-size: 0.75rem; color: #64748b; font-weight: 700; letter-spacing: 0.5px;">Payment</th>
                                <th class="py-3 text-center text-uppercase border-0" style="font-size: 0.75rem; color: #64748b; font-weight: 700; letter-spacing: 0.5px;">Actions</th>
                            </tr>
                        </thead>
                        <tbody style="transition: opacity 0.3s ease-in-out;">
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
}
else
{
    @* --- CUSTOMER MY ORDERS UI --- *@
    <div class="container my-5 max-w-4xl" style="max-width: 1000px; min-height: 60vh;">
        
        <!-- Header -->
        <h2 class="fw-bolder mb-2" style="color: #0f172a; font-size: 2rem;">My Orders</h2>
        <p class="text-muted mb-4 pb-2" style="font-size: 1.05rem;">Track, manage, and review every order you've placed.</p>

        <!-- Search input -->
        <form id="searchForm" asp-action="GetAllUserOders" asp-controller="Order" method="get">
        @if (!string.IsNullOrEmpty(Context.Request.Query["status"]))
        {
            <input type="hidden" name="status" value="@Context.Request.Query["status"]" />
        }
        <div class="mb-4" style="max-width: 350px;">
            <div class="input-group border rounded-3 bg-white" style="border-color: #cbd5e1 !important;">
                <span class="input-group-text bg-transparent border-0 text-muted ps-3 pe-2">
                    <button type="submit" class="btn p-0 m-0 border-0 text-muted hover-text-primary">
                    <i class="bi bi-search"></i>
                    </button>
                </span>
                <input type="text" id="searchInput" name="searchValue" value="@Context.Request.Query["searchValue"]" class="form-control border-0 shadow-none py-2 cust-search-input" placeholder="Search by order ID or product">
            </div>
        </div>
        </form>

        @{
            // Exclude Pending orders entirely as they represent unpaid/incomplete checkouts
            var fullList = (Model ?? Enumerable.Empty<OrderDetailsVM>())
                           .Where(o => o.OrderStatus != "Pending")
                           .ToList();

            string currentStatus = Context.Request.Query["status"].ToString();

            int countAll = fullList.Count();
            int countApproved = fullList.Count(o => o.OrderStatus == "Approved");
            int countProcessing = fullList.Count(o => o.OrderStatus == "Processing");
            int countShipped = fullList.Count(o => o.OrderStatus == "Shipped");
            int countDelivered = fullList.Count(o => o.OrderStatus == "Delivered");
            int countCancelled = fullList.Count(o => o.OrderStatus == "Cancelled");

            var displayList = string.IsNullOrEmpty(currentStatus) 
                ? fullList 
                : fullList.Where(o => o.OrderStatus.Equals(currentStatus, StringComparison.OrdinalIgnoreCase)).ToList();

            string GetBtnClass(string tabValue) => (string.IsNullOrEmpty(currentStatus) && string.IsNullOrEmpty(tabValue)) || tabValue.Equals(currentStatus, StringComparison.OrdinalIgnoreCase)
                ? "btn-dark rounded-2 px-3 py-1 fw-semibold border-0 d-flex align-items-center gap-2 me-1" 
                : "btn-white text-muted hover-bg-light rounded-2 px-3 py-1 fw-semibold border-0 d-flex align-items-center gap-2 me-1";

            string GetBadgeClass(string tabValue) => (string.IsNullOrEmpty(currentStatus) && string.IsNullOrEmpty(tabValue)) || tabValue.Equals(currentStatus, StringComparison.OrdinalIgnoreCase)
                ? "bg-white bg-opacity-25 text-white border-subtle" 
                : "bg-light text-secondary border border-subtle";
        }

        <!-- Status Filter Tabs -->
        <div class="d-flex overflow-auto mb-4 border rounded-3 p-1 bg-white align-items-center" style="border-color: #cbd5e1 !important; width: fit-content; max-width: 100%;">
            <a href="?status=" class="btn @GetBtnClass("")" style="font-size: 0.95rem;">
                All <span class="badge rounded-pill px-2 @GetBadgeClass("")">@countAll</span>
            </a>
            <a href="?status=Approved" class="btn @GetBtnClass("Approved")" style="font-size: 0.95rem;">
                Approved <span class="badge rounded-pill px-2 @GetBadgeClass("Approved")">@countApproved</span>
            </a>
            <a href="?status=Processing" class="btn @GetBtnClass("Processing")" style="font-size: 0.95rem;">
                Processing <span class="badge rounded-pill px-2 @GetBadgeClass("Processing")">@countProcessing</span>
            </a>
            <a href="?status=Shipped" class="btn @GetBtnClass("Shipped")" style="font-size: 0.95rem;">
                Shipped <span class="badge rounded-pill px-2 @GetBadgeClass("Shipped")">@countShipped</span>
            </a>
            <a href="?status=Delivered" class="btn @GetBtnClass("Delivered")" style="font-size: 0.95rem;">
                Delivered <span class="badge rounded-pill px-2 @GetBadgeClass("Delivered")">@countDelivered</span>
            </a>
            <a href="?status=Cancelled" class="btn @GetBtnClass("Cancelled") mb-0" style="font-size: 0.95rem;">
                Cancelled <span class="badge rounded-pill px-2 @GetBadgeClass("Cancelled")">@countCancelled</span>
            </a>
        </div>

        @if (!displayList.Any())
        {
            <div class="text-center py-5">
                <i class="bi bi-inbox text-muted opacity-50" style="font-size: 4rem;"></i>
                <h5 class="fw-bold text-dark mt-3">No orders found</h5>
                <p class="text-muted">You haven't placed any orders yet, or no orders match your filter.</p>
            </div>
        }
        else
        {
            <!-- Cards list -->
            <div class="d-flex flex-column gap-4">
                @foreach (var order in displayList)
                {
                    <div class="card bg-white border rounded-4 overflow-hidden" style="border-color: #e2e8f0 !important; box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.05);">
                        
                        <!-- Top Info Row -->
                        <div class="d-flex flex-wrap justify-content-between align-items-center p-3 border-bottom" style="border-color: #f1f5f9 !important;">
                            <div class="d-flex flex-wrap gap-3 gap-md-5">
                                <div>
                                    <span class="d-block text-muted fw-bold mb-1" style="font-size: 0.65rem; letter-spacing: 0.5px;">ORDER ID</span>
                                    <span class="fw-bolder text-dark" style="font-size: 0.95rem;">ORD-@order.Id</span>
                                </div>
                                <div>
                                    <span class="d-block text-muted fw-bold mb-1" style="font-size: 0.65rem; letter-spacing: 0.5px;">DATE</span>
                                    <span class="fw-bolder text-dark" style="font-size: 0.95rem;">@(order.OrderDate != DateTime.MinValue ? order.OrderDate.ToString("MMM dd, yyyy") : "")</span>
                                </div>
                                <div>
                                    <span class="d-block text-muted fw-bold mb-1" style="font-size: 0.65rem; letter-spacing: 0.5px;">TOTAL</span>
                                    <span class="fw-bolder text-dark" style="font-size: 0.95rem;">@order.OrderTotal.ToString("c")</span>
                                </div>
                            </div>

                                <div class="mt-3 mt-md-0">
                                    @{
                                        string badgeStyle = order.OrderStatus switch {
                                            "Approved" => "background-color: #e0e7ff; color: #4338ca; border-color: #c7d2fe;",
                                            "Processing" => "background-color: #fef3c7; color: #b45309; border-color: #fde68a;",
                                            "Shipped" => "background-color: #e0f2fe; color: #0369a1; border-color: #bae6fd;",
                                            "Delivered" => "background-color: #dcfce7; color: #15803d; border-color: #bbf7d0;",
                                            "Cancelled" => "background-color: #fee2e2; color: #b91c1c; border-color: #fecaca;",
                                            _ => "background-color: #f1f5f9; color: #475569; border-color: #e2e8f0;"
                                        };
                                        
                                        string badgeIcon = order.OrderStatus switch {
                                            "Delivered" => "bi-check-circle",
                                            "Shipped" => "bi-truck",
                                            "Processing" => "bi-gear",
                                            "Approved" => "bi-check2-circle",
                                            "Cancelled" => "bi-x-circle",
                                            _ => "bi-clock"
                                        };
                                    }
                                    <div class="badge rounded-pill px-3 py-2 fw-bold d-inline-flex align-items-center" style="@badgeStyle border: 1px solid; font-size: 0.8rem; letter-spacing: 0.5px;">
                                        <i class="bi @badgeIcon me-2" style="font-size: 0.9rem;"></i> <span class="text-uppercase">@order.OrderStatus</span>
                                    </div>
                                </div>
                        </div>

                        <!-- Middle Products Row -->
                        <div class="px-4 py-3 d-flex justify-content-between align-items-center">
                            <div class="d-flex align-items-center">
                                @if(order.Items != null && order.Items.Any())
                                {
                                    <div class="d-flex position-relative align-items-center" style="height: 65px;">
                                        @{
                                            var previewItems = order.Items.Take(3).ToList();
                                            for(int i = 0; i < previewItems.Count; i++)
                                            {
                                                var imgPath = previewItems[i].ImageUrl;
                                                if(!string.IsNullOrEmpty(imgPath))
                                                {

                                                    <img src="~/@imgPath" class="rounded-4 shadow-sm position-absolute" style="width: 80px; height: 80px; left: @(i * 40)px; z-index: @(10 - i); object-fit: cover; border: 2px solid white !important;" onerror="this.onerror=null; this.outerHTML='<div class=\'rounded-4 bg-light d-flex justify-content-center align-items-center shadow-sm position-absolute\' style=\'width: 65px; height: 65px; left: @(i * 40)px; z-index: @(10 - i); border: 2px solid white !important;\'><i class=\'bi bi-image text-muted opacity-50\'></i></div>';" />
                                                }
                                                else
                                                {
                                                    <div class="rounded-4 bg-light d-flex justify-content-center align-items-center shadow-sm position-absolute" style="width: 65px; height: 65px; left: @(i * 40)px; z-index: @(10 - i); border: 2px solid white !important;">
                                                        <i class="bi bi-image text-secondary opacity-50"></i>
                                                    </div>
                                                }
                                            }
                                        }
                                        <div style="width: @(65 + (previewItems.Count - 1) * 40)px;"></div>
                                    </div>
                                }
                                else
                                {
                                    <div class="rounded-4 bg-light shadow-sm d-flex justify-content-center align-items-center" style="width: 65px; height: 65px; border: 2px solid white !important;">
                                        <i class="bi bi-box text-muted fs-4"></i>
                                    </div>
                                }
                            </div>
                            
                            <div class="text-muted fw-semibold" style="font-size: 0.85rem;">
                                @(order.Items?.Count ?? 0) items
                            </div>
                        </div>

                        <!-- Bottom Footer Row -->
                        <div class="px-3 py-3 bg-white border-top d-flex flex-column flex-sm-row justify-content-between align-items-start align-items-sm-center gap-3" style="border-color: #f1f5f9 !important;">
                            <div class="text-muted fw-medium text-truncate pe-sm-3 w-100" style="font-size: 0.85rem; max-width: 100%;">
                                @if(order.Items != null && order.Items.Any())
                                {
                                    @order.Items.First().Title
                                    @if(order.Items.Count > 1)
                                    {
                                        <span> and @(order.Items.Count - 1) more</span>
                                    }
                                }
                                else
                                {
                                    <span>Products detail unavailable</span>
                                }
                            </div>
                            
                            <a asp-action="Details" asp-controller="Order" asp-route-id="@order.Id" class="btn btn-primary rounded-pill px-4 fw-semibold shadow-sm d-flex align-items-center gap-2" style="font-size: 0.95rem;">
                                View Details <i class="bi bi-chevron-right" style="font-size: 0.8rem;"></i>
                            </a>
                        </div>
                    </div>
                }
            </div>
        }
    </div>
}

@section Scripts {
    @if (isAdmin)
    {
        <script src="~/js/order.js"></script>
        <style>
            .custom-filter-dropdown { z-index: 1050; }
            .custom-filter-dropdown .btn:hover { transform: translateY(-2px); box-shadow: 0 8px 15px rgba(79, 70, 229, 0.3) !important; }
            .custom-filter-dropdown .dropdown-toggle::after { display: none; }
            .custom-filter-dropdown.show #dropdownChevron { transform: rotate(180deg); }
            .animated-dropdown { animation: fadeInDropdown 0.2s cubic-bezier(0.4, 0, 0.2, 1) forwards; transform-origin: top right; }
            @@keyframes fadeInDropdown {
                from { opacity: 0; transform: scale(0.95) translateY(-5px); }
                to { opacity: 1; transform: scale(1) translateY(0); }
            }
            .filter-dropdown-btn { font-weight: 600; color: #4b5563; transition: all 0.2s ease; padding: 10px 16px; }
            .filter-dropdown-btn:hover { background-color: #f3f4f6; color: #111827; transform: translateX(4px); }
            .filter-dropdown-btn.active { background-color: #eef2ff; color: #4f46e5; box-shadow: inset 3px 0 0 #4f46e5; }

        </style>
    }
    else
    {
        <style>
            body { background-color: var(--bg-main); }
            .hover-bg-light:hover { background-color: #f1f5f9 !important; }
            .cust-search-input:focus { outline: none !important; box-shadow: none !important; }
            
            /* Add some responsive utilities */
            @@media (max-width: 576px) {
                .bottom-footer-row { flex-direction: column; align-items: start !important; gap: 15px; }
            }
        </style>

        <script>
            document.addEventListener("DOMContentLoaded", function () {
                const searchInput = document.getElementById('searchInput');
                const searchForm = document.getElementById('searchForm');
                let searchTimeout;

                if (searchInput && searchForm) {
                    // Restore cursor to the end of the input if there is a value
                    const val = searchInput.value;
                    if (val) {
                        searchInput.focus();
                        searchInput.value = '';
                        searchInput.value = val;
                    }

                    // Keep it extremely simple: ANY input triggers a submit after 500ms
                    searchInput.addEventListener('input', function () {
                        clearTimeout(searchTimeout);
                        searchTimeout = setTimeout(() => {
                            searchForm.submit();
                        }, 500);
                    });
                }
            });
        </script>
    }
}
