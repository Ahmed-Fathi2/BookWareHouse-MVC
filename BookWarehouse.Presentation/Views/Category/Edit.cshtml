@model BookWarehouse.Application.ViewModels.Category.CategoryReadEditVM

<div class="container mt-5 mb-5 pb-5">
    <div class="row justify-content-center">
        <div class="col-lg-8">
            <div class="card shadow-lg border-0 mb-4">
                <div class="card-header bg-primary text-white py-4 px-5 border-0 text-center">
                    <h2 class="mb-0 fw-bold"><i class="bi bi-pencil-square me-2"></i>Edit Category</h2>
                    <p class="mb-0 text-white-50 mt-1">Make changes and update the category specifics.</p>
                </div>
                <div class="card-body p-4 p-md-5">
                    <form method="post" asp-controller="Category" asp-action="SaveEdit" asp-route-id="@Model.Id" enctype="multipart/form-data">
                        <input type="hidden" asp-for="ImageUrl" />
                        <div asp-validation-summary="ModelOnly" class="alert alert-danger mb-4 rounded-3 border-0 shadow-sm"></div>

                        <h4 class="section-title"><i class="bi bi-info-circle"></i> Category Details</h4>

                        <div class="row">
                            <div class="col-md-9">
                                <div class="mb-4">
                                    <label asp-for="Name" class="form-label"></label>
                                    <input asp-for="Name" class="form-control form-control-lg" placeholder="e.g. Fiction, Non-Fiction, Sci-Fi..." />
                                    <span asp-validation-for="Name" class="text-danger small mt-1 d-block"></span>
                                </div>

                                <div class="mb-4">
                                    <label asp-for="Description" class="form-label"></label>
                                    <textarea asp-for="Description" class="form-control form-control-lg" rows="4" placeholder="Enter a brief description of the category..."></textarea>
                                    <span asp-validation-for="Description" class="text-danger small mt-1 d-block"></span>
                                </div>

                                <div class="mb-4">
                                    <label asp-for="DisplayOrder" class="form-label"></label>
                                    <input asp-for="DisplayOrder" class="form-control form-control-lg" placeholder="e.g. 1" />
                                    <span asp-validation-for="DisplayOrder" class="text-danger small mt-1 d-block"></span>
                                </div>

                                <div class="mb-4">
                                    <label for="image" class="form-label">Category Image (Leave empty to keep existing)</label>
                                    <input type="file" name="image" id="image" class="form-control form-control-lg" accept="image/*" />
                                    <span class="text-muted small mt-1 d-block">Max size 5MB.</span>
                                </div>
                            </div>
                            <div class="col-md-3">
                                <div class="mb-3 text-center">
                                    <label class="form-label d-block text-muted">Current Image</label>
                                    @if (!string.IsNullOrEmpty(Model.ImageUrl))
                                    {
                                        <img src="~/@Model.ImageUrl" alt="Current Image" class="img-fluid rounded shadow-sm border" style="max-height: 200px; object-fit: cover;" />
                                    }
                                    else
                                    {
                                        <div class="bg-light rounded p-4 text-muted border text-center">
                                            <i class="bi bi-image" style="font-size: 3rem;"></i>
                                            <p class="mb-0 small">No Image</p>
                                        </div>
                                    }
                                </div>
                            </div>
                        </div>

                        <div class="d-flex align-items-center justify-content-end gap-3 mt-5 pt-4 border-top">
                            <a asp-action="Index" class="btn btn-outline-secondary btn-lg px-4">
                                <i class="bi bi-arrow-left me-2"></i> Cancel
                            </a>
                            <button type="submit" class="btn btn-primary btn-lg px-5 shadow">
                                <i class="bi bi-check-circle-fill me-2"></i> Save Changes
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}