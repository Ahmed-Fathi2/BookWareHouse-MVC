@model BookWarehouse.Application.ViewModels.Category.CategoryReadEditVM

<div class="container mt-5 mb-5 pb-5">
    <div class="row justify-content-center">
        <div class="col-lg-8">
            <div class="card shadow-lg border-0 rounded-4 overflow-hidden mb-4">
                <div class="card-header bg-danger text-white py-4 border-0 text-center">
                    <h2 class="mb-0 fw-bold"><i class="bi bi-exclamation-triangle-fill fs-3 me-2"></i>Delete Category</h2>
                </div>
                
                <div class="card-body p-4 p-md-5">
                    <div class="alert alert-warning border-0 shadow-sm rounded-3 mb-5 p-4 d-flex align-items-center">
                        <i class="bi bi-info-circle-fill me-4 fs-1 text-warning"></i>
                        <div>
                            <h4 class="alert-heading fw-bold mb-1 text-dark">Warning: Permanent Deletion</h4>
                            <p class="mb-0 text-dark">You are about to perfectly permanently delete the category <strong>@Model.Name</strong>. This action cannot be undone.</p>
                        </div>
                    </div>

                    <form method="post" asp-controller="Category" asp-action="SaveDelete" asp-route-id="@Model.Id">
                        
                        <h4 class="section-title"><i class="bi bi-tag"></i> Category Summary</h4>

                        <div class="mb-5">
                            <label asp-for="Name" class="form-label"></label>
                            <input asp-for="Name" class="form-control form-control-lg text-muted bg-light border-0 shadow-none" disabled />
                        </div>

                        <div class="mb-5">
                            <label asp-for="DisplayOrder" class="form-label"></label>
                            <input asp-for="DisplayOrder" class="form-control form-control-lg text-muted bg-light border-0 shadow-none" disabled />
                        </div>

                        <div class="d-flex justify-content-end gap-3 mt-4 pt-4 border-top">
                            <a asp-action="Index" class="btn btn-outline-secondary btn-lg px-4 fw-semibold shadow-sm">
                                <i class="bi bi-arrow-left me-2"></i>Cancel
                            </a>
                            <button type="submit" class="btn btn-danger btn-lg px-5 fw-bold shadow">
                                <i class="bi bi-trash-fill me-2"></i>Delete Category
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>