@model ForgotPasswordVM

@{
    ViewData["Title"] = "Forgot Password";
}

<div class="d-flex justify-content-center align-items-center w-100 py-2" style="min-height: calc(100vh - 150px);">
    <div class="w-100 px-3" style="max-width: 500px;">
        <div class="card border-0 p-3 p-md-4" style="border-radius: 20px; box-shadow: 0 10px 40px rgba(0,0,0,0.05); background-color: #ffffff;">
            <div class="text-center mb-3">
                <i class="bi bi-shield-lock display-5 mb-2" style="color: #2563eb;"></i>
                <h2 class="fw-bolder mb-1" style="color: #0f172a; letter-spacing: -0.5px; font-size: 1.75rem;">Forgot Password?</h2>
                <p class="mb-0" style="color: #64748b; font-size: 0.95rem;">Enter your email to reset your password</p>
            </div>

            <form asp-action="ForgotPassword" method="post">
                <div asp-validation-summary="ModelOnly" class="validation-summary-box mb-3"></div>

                <div class="mb-3 form-group">
                    <div class="d-flex justify-content-between align-items-center mb-1">
                        <label asp-for="Email" class="form-label fw-bold mb-0" style="color: #0f172a; font-size: 0.95rem;">Email address</label>
                    </div>
                    <div class="position-relative">
                        <i class="bi bi-envelope position-absolute" style="left: 1rem; top: 50%; transform: translateY(-50%); font-size: 1.1rem; color: #64748b;"></i>
                        <input asp-for="Email" class="form-control bg-white" placeholder="you@example.com" autofocus autocomplete="email" style="border-radius: 10px; border: 1px solid #e2e8f0; font-size: 0.95rem; padding-left: 2.8rem; padding-top: 0.5rem; padding-bottom: 0.5rem;" />
                    </div>
                    <span asp-validation-for="Email" class="text-danger small mt-1 d-block fw-semibold"></span>
                </div>

                <div class="d-grid mb-3">
                    <button type="submit" class="btn text-white btn-lg fw-bold shadow-sm d-flex justify-content-center align-items-center gap-2 login-btn" style="background-color: #2563eb; border-radius: 12px; font-size: 1rem; padding: 0.6rem; transition: all 0.2s;">
                        Send Reset Link
                    </button>
                </div>
            </form>

            <div class="text-center mt-3 pt-3 border-top" style="border-color: #f1f5f9 !important;">
                <p class="mb-0 fw-medium" style="color: #64748b; font-size: 0.95rem;">
                    Remember your password? <a asp-action="Login" class="text-decoration-none fw-bold" style="color: #2563eb;">Sign In</a>
                </p>
            </div>
        </div>
    </div>
</div>

<style>
    body {
        background-color: #F8FAFC !important;
        overflow: hidden !important;
    }
    .login-btn:hover {
        background-color: #1d4ed8 !important;
        transform: translateY(-2px);
        box-shadow: 0 4px 15px rgba(37,99,235,0.2) !important;
    }
    .form-control:focus {
        border-color: #2563eb !important;
        box-shadow: 0 0 0 0.25rem rgba(37,99,235,0.1) !important;
    }
    .validation-summary-box {
        background-color: #fff1f2;
        border: 1px solid #ffe4e6;
        color: #e11d48;
        padding: 0.75rem 1rem;
        border-radius: 10px;
        font-size: 0.85rem;
        font-weight: 600;
    }
    .validation-summary-box ul {
        list-style: none;
        margin: 0;
        padding: 0;
    }
    .validation-summary-errors ul li::before {
        content: "\F333";
        font-family: "bootstrap-icons";
        margin-right: 8px;
    }
</style>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
