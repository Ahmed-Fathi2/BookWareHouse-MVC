@model ForgotPasswordVM

@{
    ViewData["Title"] = "Forgot Password";
}

<div class="auth-wrapper d-flex align-items-center justify-content-center py-4">
    <div class="auth-container p-3 p-md-0 w-100" style="max-width: 500px;">
        <div class="card auth-card border-0 shadow-lg" style="border-radius: 24px; overflow: hidden; background-color: #ffffff;">
            <div class="card-body p-4 p-md-5">
                
                <!-- Logo & Header -->
                <div class="text-center mb-4">
                    <div class="bg-primary text-white rounded-4 d-inline-flex align-items-center justify-content-center mb-3 shadow-sm" style="width: 54px; height: 54px;">
                        <i class="bi bi-shield-lock" style="font-size: 1.8rem;"></i>
                    </div>
                    <h2 class="fw-bolder mb-1 text-dark" style="letter-spacing: -0.8px; font-size: 1.75rem;">Forgot Password?</h2>
                    <p class="text-muted mb-0" style="font-size: 0.95rem;">Enter your email to reset your password</p>
                </div>

                <form asp-action="ForgotPassword" method="post">
                    <div asp-validation-summary="ModelOnly" class="validation-summary-box mb-4"></div>

                    <!-- Email Field -->
                    <div class="mb-4">
                        <label asp-for="Email" class="form-label text-dark fw-bold mb-2" style="font-size: 0.85rem; letter-spacing: 0.3px; text-transform: uppercase;">Email Address</label>
                        <div class="position-relative">
                            <i class="bi bi-envelope position-absolute auth-icon"></i>
                            <input asp-for="Email" class="form-control auth-input" placeholder="name@example.com" autofocus autocomplete="email" />
                        </div>
                        <span asp-validation-for="Email" class="text-danger small mt-1 d-block fw-semibold"></span>
                    </div>

                    <!-- Submit Button -->
                    <div class="d-grid mb-3">
                        <button type="submit" class="btn btn-primary btn-lg auth-submit shadow-sm py-3 border-0" style="font-size: 1rem; letter-spacing: 0.5px;">
                            Send Reset Link <i class="bi bi-arrow-right ms-2"></i>
                        </button>
                    </div>
                </form>
            </div>

            <!-- Footer Link -->
            <div class="p-4 bg-light border-top text-center" style="background-color: #F9FAFB !important;">
                <p class="mb-0 fw-medium text-muted" style="font-size: 0.95rem;">
                    Remember your password? <a asp-action="Login" class="text-decoration-none fw-bold" style="color: var(--brand-primary);">Sign In</a>
                </p>
            </div>
        </div>
    </div>
</div>

<style>
    header, footer {
        display: none !important;
    }

    body {
        background-color: var(--bg-main) !important;
        height: 100vh;
    }

    .auth-wrapper {
        min-height: calc(100vh - 120px);
    }

    .auth-input {
        height: 52px;
        border-radius: 12px;
        border: 1.5px solid var(--border-color);
        padding-left: 3.2rem;
        font-size: 1rem;
        transition: all 0.25s ease;
        background-color: #ffffff;
    }

    .auth-input:focus {
        border-color: var(--brand-primary) !important;
        box-shadow: 0 0 0 4px rgba(15, 118, 110, 0.1) !important;
        background-color: #ffffff;
    }

    .auth-icon {
        left: 1.2rem; 
        top: 50%; 
        transform: translateY(-50%); 
        font-size: 1.1rem; 
        color: var(--brand-muted);
    }

    .auth-submit {
        border-radius: 12px;
        transition: all 0.3s ease;
    }

    .auth-submit:hover {
        background-color: var(--brand-primary-hover) !important;
        transform: translateY(-2px);
        box-shadow: 0 10px 20px rgba(15, 118, 110, 0.2) !important;
    }

    .validation-summary-box {
        background-color: #FEF2F2;
        border-radius: 12px;
        padding: 1rem;
        color: #B91C1C;
        font-size: 0.85rem;
    }
    
    .validation-summary-box ul {
        margin: 0; padding-left: 1.2rem;
    }
</style>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
