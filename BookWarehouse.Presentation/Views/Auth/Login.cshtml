@model BookWarehouse.Application.ViewModels.Auth.LoginVM

@{
    ViewData["Title"] = "Sign In";
}

<div class="row justify-content-center align-items-center mb-5 mt-5">
    <div class="col-md-7 col-lg-6 col-xl-5">
        <div class="card shadow-lg p-4 p-md-5">
            <div class="text-center mb-4">
                <i class="bi bi-person-circle display-3 text-primary mb-3"></i>
                <h2 class="fw-bolder text-primary">Welcome Back</h2>
                <p class="text-secondary">Please sign in to your account</p>
            </div>

            <form asp-action="Login">
                <div asp-validation-summary="ModelOnly" class="alert alert-danger rounded" role="alert"></div>

                <div class="mb-4 form-group">
                    <label asp-for="Email" class="form-label">Email Address</label>
                    <div class="input-group">
                        <span class="input-group-text bg-light border-end-0 px-3"><i class="bi bi-envelope text-muted"></i></span>
                        <input asp-for="Email" class="form-control form-control-lg border-start-0 ps-0" placeholder="name@example.com" autofocus autocomplete="email" />
                    </div>
                    <span asp-validation-for="Email" class="text-danger small mt-1 d-block fw-semibold"></span>
                </div>

                <div class="mb-4 form-group">
                    <label asp-for="Password" class="form-label">Password</label>
                    <div class="input-group">
                        <span class="input-group-text bg-light border-end-0 px-3"><i class="bi bi-lock text-muted"></i></span>
                        <input asp-for="Password" type="password" class="form-control form-control-lg border-start-0 ps-0" placeholder="••••••••" autocomplete="current-password" />
                    </div>
                    <span asp-validation-for="Password" class="text-danger small mt-1 d-block fw-semibold"></span>
                </div>

                <div class="d-flex justify-content-between align-items-center mb-4">
                    <div class="form-check">
                        <input class="form-check-input" asp-for="RememberMe" />
                        <label class="form-check-label text-secondary fw-medium" asp-for="RememberMe">
                            @Html.DisplayNameFor(model => model.RememberMe)
                        </label>
                    </div>
                    @* Placeholder for a future forgot password feature *@
                    @* <a href="#" class="text-decoration-none small fw-semibold text-primary">Forgot Password?</a> *@
                </div>

                <div class="d-grid mb-4">
                    <button type="submit" class="btn btn-primary btn-lg fw-bold shadow-sm">
                        <i class="bi bi-box-arrow-in-right me-2"></i> Sign In
                    </button>
                </div>
            </form>

            <div class="text-center mt-2 border-top pt-4">
                <p class="text-secondary mb-0">
                    Don't have an account? <a asp-action="Register" class="text-decoration-none fw-bold text-primary">Create one</a>
                </p>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
