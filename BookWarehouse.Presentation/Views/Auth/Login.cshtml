@model LoginVM

@{
    ViewData["Title"] = "Sign In";
}

<div class="auth-split-container">
    <div class="row g-0 h-100">
        <!-- Left Side: Image/Branding -->
        <div class="col-lg-6 d-none d-lg-block position-relative h-100 overflow-hidden">
            <!-- Blurred Background Image -->
            <div class="position-absolute top-0 start-0 w-100 h-100" style="background-image: url('https://images.unsplash.com/photo-1544947950-fa07a98d237f?ixlib=rb-4.0.3&auto=format&fit=crop&w=1600&q=80'); background-size: cover; background-position: center; filter: blur(4px); transform: scale(1.05);"></div>
            <!-- Teal Overlay -->
            <div class="overlay"></div>
            
            <div class="position-relative h-100 d-flex flex-column justify-content-center align-items-center text-white p-5">
                <div class="text-center" style="z-index: 2;">
                    <h1 class="display-3 fw-bolder mb-3" style="letter-spacing: -1.5px;">Readify.</h1>
                    <p class="lead fw-medium mb-0" style="opacity: 0.9;">Your gateway to an infinite world of knowledge and stories.</p>
                </div>
            </div>
        </div>

        <!-- Right Side: Form -->
        <div class="col-lg-6 d-flex justify-content-center align-items-center auth-form-wrapper">
            <div class="auth-form-inner w-100 px-4 px-md-5">
                <!-- Mobile Logo -->
                <div class="text-center d-lg-none mb-4 mt-3">
                    <h1 class="fw-bolder text-dark" style="letter-spacing: -1px; color: var(--brand-primary) !important;">Readify.</h1>
                </div>

                <div class="text-center mb-5">
                    <h2 class="fw-bolder mb-2 text-dark" style="letter-spacing: -0.5px; font-size: 2rem;">Welcome back</h2>
                    <p class="text-muted" style="font-size: 1.05rem;">Please enter your details to sign in.</p>
                </div>

                <form asp-action="Login">
                    <div asp-validation-summary="ModelOnly" class="validation-summary-box mb-4"></div>

                    <!-- Email Field -->
                    <div class="mb-4">
                        <label asp-for="Email" class="form-label text-dark fw-bold mb-2" style="font-size: 0.9rem; letter-spacing: 0.5px; text-transform: uppercase;">Email Address</label>
                        <div class="position-relative">
                            <i class="bi bi-envelope position-absolute auth-icon"></i>
                            <input asp-for="Email" class="form-control auth-input" placeholder="name@example.com" autofocus autocomplete="email" />
                        </div>
                        <span asp-validation-for="Email" class="text-danger small mt-1 d-block fw-semibold"></span>
                    </div>

                    <!-- Password Field -->
                    <div class="mb-4">
                        <div class="d-flex justify-content-between align-items-center mb-2">
                            <label asp-for="Password" class="form-label text-dark fw-bold mb-0" style="font-size: 0.9rem; letter-spacing: 0.5px; text-transform: uppercase;">Password</label>
                            <a asp-action="ForgotPassword" asp-controller="Auth" class="text-decoration-none small fw-bold" style="color: var(--brand-primary);">Forgot password?</a>
                        </div>
                        <div class="position-relative">
                            <i class="bi bi-shield-lock position-absolute auth-icon"></i>
                            <input asp-for="Password" type="password" id="Password" class="form-control auth-input" placeholder="••••••••" autocomplete="current-password" />
                            <i class="bi bi-eye position-absolute show-pass-icon" onclick="const input = document.getElementById('Password'); if(input.type === 'password') { input.type = 'text'; this.classList.replace('bi-eye', 'bi-eye-slash'); } else { input.type = 'password'; this.classList.replace('bi-eye-slash', 'bi-eye'); }"></i>
                        </div>
                        <span asp-validation-for="Password" class="text-danger small mt-1 d-block fw-semibold"></span>
                    </div>
                    
                    <!-- Remember Me -->
                    <div class="d-flex align-items-center mb-4">
                        <div class="form-check custom-check">
                            <input class="form-check-input" asp-for="RememberMe" />
                            <label class="form-check-label fw-medium text-muted ms-2" asp-for="RememberMe" style="font-size: 1rem; cursor: pointer;">
                                Keep me signed in
                            </label>
                        </div>
                    </div>

                    <div class="d-grid mb-4">
                        <button type="submit" class="btn btn-primary btn-lg auth-submit shadow-sm py-3 border-0 d-flex justify-content-center align-items-center gap-2" style="font-size: 1.05rem; letter-spacing: 0.5px; text-transform: uppercase; font-weight: 700;">
                            <i class="bi bi-box-arrow-in-right fs-5"></i> Sign In
                        </button>
                    </div>
                </form>

                <!-- Social Login -->
                <div class="position-relative mb-3 text-center mt-4">
                    <hr class="w-100" style="border-color: #E5E7EB; opacity: 1;">
                    <span class="position-absolute top-50 start-50 translate-middle bg-white px-3 text-muted fw-medium" style="font-size: 0.85rem; letter-spacing: 1px;">OR CONTINUE WITH</span>
                </div>

                <div class="d-grid mb-4">
                    <form asp-action="ExternalLogin" asp-controller="Auth" method="post" class="w-100">
                        <input type="hidden" name="provider" value="Google" />
                        <button type="submit" class="btn w-100 d-flex align-items-center justify-content-center bg-white external-btn" style="border: 1px solid #D1D5DB; color: #374151; font-weight: 600; padding: 0.8rem; border-radius: 12px; font-size: 1rem; transition: all 0.2s ease;">
                            <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" preserveAspectRatio="xMidYMid" viewBox="0 0 256 262" class="me-3">
                                <path fill="#4285F4" d="M255.878 133.451c0-10.734-.871-18.567-2.756-26.69H130.55v48.448h71.947c-1.45 12.04-9.283 30.153-26.69 42.356l-.244 1.622 38.755 30.023 2.685.268c24.659-22.774 38.875-56.282 38.875-96.027"/>
                                <path fill="#34A853" d="M130.55 261.1c35.248 0 64.839-11.605 86.453-31.622l-41.196-31.913c-11.024 7.688-25.82 13.055-45.257 13.055-34.523 0-63.824-22.773-74.269-54.25l-1.531.13-40.298 31.187-.527 1.465C35.393 231.798 79.49 261.1 130.55 261.1"/>
                                <path fill="#FBBC05" d="M56.281 156.37c-2.756-8.123-4.351-16.827-4.351-25.82 0-8.994 1.595-17.697 4.206-25.82l-.073-1.73L15.26 71.312l-1.335.635C5.077 89.644 0 109.517 0 130.55s5.077 40.905 13.925 58.602l42.356-32.782"/>
                                <path fill="#EA4335" d="M130.55 50.479c24.514 0 41.05 10.589 50.479 19.438l36.844-35.974C195.245 12.91 165.798 0 130.55 0 79.49 0 35.393 29.301 13.925 71.947l42.211 32.783c10.59-31.477 39.891-54.251 74.414-54.251"/>
                            </svg>
                            Continue with Google
                        </button>
                    </form>
                </div>

                <!-- Footer Link -->
                <div class="text-center mt-auto pb-4">
                    <p class="mb-0 fw-medium text-muted" style="font-size: 1rem;">
                        New to Readify? <a asp-action="Register" class="text-decoration-none fw-bold" style="color: var(--brand-primary); padding-bottom: 2px; border-bottom: 2px solid var(--brand-primary);">Create account</a>
                    </p>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    body {
        margin: 0;
        padding: 0;
        background-color: #ffffff !important;
        overflow-x: hidden;
    }

    /* Hide the main layout header/footer for auth pages to give full screen experience */
    header, footer {
        display: none !important;
    }

    .auth-split-container {
        height: 100vh;
        width: 100%;
    }

    .overlay {
        position: absolute;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        background: linear-gradient(135deg, rgba(15, 118, 110, 0.85) 0%, rgba(17, 24, 39, 0.9) 100%);
    }

    .auth-form-wrapper {
        background-color: #ffffff;
        padding: 2rem 0;
        overflow-y: auto;
    }

    .auth-form-inner {
        max-width: 520px;
    }

    .auth-input {
        height: 56px;
        border-radius: 12px;
        border: 1.5px solid #E5E7EB;
        padding-left: 3.5rem;
        font-size: 1.05rem;
        transition: all 0.3s ease;
        background-color: #F9FAFB;
        color: #111827;
    }

    .auth-input:focus {
        border-color: var(--brand-primary) !important;
        box-shadow: 0 0 0 4px rgba(15, 118, 110, 0.1) !important;
        background-color: #ffffff;
    }

    .auth-icon {
        left: 1.4rem; 
        top: 50%; 
        transform: translateY(-50%); 
        font-size: 1.25rem; 
        color: #9CA3AF;
        z-index: 5;
    }

    .show-pass-icon {
        right: 1.4rem; 
        top: 50%; 
        transform: translateY(-50%); 
        font-size: 1.25rem; 
        cursor: pointer; 
        color: #9CA3AF;
        z-index: 5;
        transition: color 0.2s;
    }
    
    .show-pass-icon:hover {
        color: var(--brand-primary);
    }

    .auth-submit {
        border-radius: 12px;
        transition: all 0.3s ease;
        background-color: var(--brand-primary);
    }

    .auth-submit:hover {
        background-color: var(--brand-primary-hover) !important;
        transform: translateY(-2px);
        box-shadow: 0 10px 25px rgba(15, 118, 110, 0.25) !important;
    }

    .external-btn:hover {
        background-color: #F9FAFB !important;
        border-color: #9CA3AF !important;
        transform: translateY(-2px);
        box-shadow: 0 8px 20px rgba(0,0,0,0.06) !important;
    }

    .validation-summary-box {
        background-color: #FEF2F2;
        border: 1px solid #FCA5A5;
        border-radius: 12px;
        padding: 1.2rem;
        color: #B91C1C;
        font-size: 0.95rem;
    }
    
    .validation-summary-box ul {
        margin: 0; padding-left: 1.2rem;
    }

    .form-check-input:checked {
        background-color: var(--brand-primary);
        border-color: var(--brand-primary);
    }
</style>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
