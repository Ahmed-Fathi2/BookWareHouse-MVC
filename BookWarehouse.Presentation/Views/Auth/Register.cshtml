@model RegisterVM

@{
    ViewData["Title"] = "Create Account";
}

<div class="auth-split-container">
    <div class="row g-0 h-100 flex-row-reverse">
        <!-- Right Side: Image/Branding -->
        <div class="col-lg-6 d-none d-lg-block position-relative h-100 overflow-hidden">
            <!-- Blurred Background Image -->
            <div class="position-absolute top-0 start-0 w-100 h-100" style="background-image: url('https://images.unsplash.com/photo-1495446815901-a7297e633e8d?ixlib=rb-4.0.3&auto=format&fit=crop&w=1600&q=80'); background-size: cover; background-position: center; filter: blur(4px); transform: scale(1.05);"></div>
            <!-- Teal Overlay -->
            <div class="overlay"></div>
            
            <div class="position-relative h-100 d-flex flex-column justify-content-center align-items-center text-white p-5">
                <div class="text-center" style="z-index: 2;">
                    <h1 class="display-3 fw-bolder mb-3" style="letter-spacing: -1.5px;">Readify.</h1>
                    <p class="lead fw-medium mb-0" style="opacity: 0.9;">Join us and start managing your infinite library.</p>
                </div>
            </div>
        </div>

        <!-- Left Side: Form -->
        <div class="col-lg-6 d-flex justify-content-center align-items-center auth-form-wrapper">
            <div class="auth-form-inner w-100 px-4 px-md-5">
                <!-- Mobile Logo -->
                <div class="text-center d-lg-none mb-4 mt-3">
                    <h1 class="fw-bolder text-dark" style="letter-spacing: -1px; color: var(--brand-primary) !important;">Readify.</h1>
                </div>

                <div class="text-center mb-5">
                    <h2 class="fw-bolder mb-2 text-dark" style="letter-spacing: -0.5px; font-size: 2rem;">Create account</h2>
                    <p class="text-muted" style="font-size: 1.05rem;">Enter your details to join Readify today.</p>
                </div>

                <form asp-action="Register" asp-controller="Auth" method="post">
                    <div asp-validation-summary="ModelOnly" class="validation-summary-box mb-4"></div>

                    <!-- Name Fields (Two Columns) -->
                    <div class="row g-3 mb-4">
                        <div class="col-md-6">
                            <label asp-for="FirstName" class="form-label text-dark fw-bold mb-2" style="font-size: 0.9rem; letter-spacing: 0.5px; text-transform: uppercase;">First Name</label>
                            <div class="position-relative">
                                <i class="bi bi-person position-absolute auth-icon"></i>
                                <input asp-for="FirstName" class="form-control auth-input" placeholder="Ahmed" autofocus />
                            </div>
                            <span asp-validation-for="FirstName" class="text-danger small mt-1 d-block fw-semibold"></span>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="LastName" class="form-label text-dark fw-bold mb-2" style="font-size: 0.9rem; letter-spacing: 0.5px; text-transform: uppercase;">Last Name</label>
                            <div class="position-relative">
                                <i class="bi bi-person-badge position-absolute auth-icon"></i>
                                <input asp-for="LastName" class="form-control auth-input" placeholder="Fathi" />
                            </div>
                            <span asp-validation-for="LastName" class="text-danger small mt-1 d-block fw-semibold"></span>
                        </div>
                    </div>

                    <!-- Email Field -->
                    <div class="mb-4">
                        <label asp-for="Email" class="form-label text-dark fw-bold mb-2" style="font-size: 0.9rem; letter-spacing: 0.5px; text-transform: uppercase;">Email Address</label>
                        <div class="position-relative">
                            <i class="bi bi-envelope position-absolute auth-icon"></i>
                            <input asp-for="Email" class="form-control auth-input" placeholder="name@example.com" autocomplete="email" />
                        </div>
                        <span asp-validation-for="Email" class="text-danger small mt-1 d-block fw-semibold"></span>
                    </div>

                    <!-- Password Fields (Two Columns) -->
                    <div class="row g-3 mb-4">
                        <div class="col-md-6">
                            <label asp-for="Password" class="form-label text-dark fw-bold mb-2" style="font-size: 0.9rem; letter-spacing: 0.5px; text-transform: uppercase;">Password</label>
                            <div class="position-relative">
                                <i class="bi bi-shield-lock position-absolute auth-icon"></i>
                                <input asp-for="Password" type="password" id="Password" class="form-control auth-input pe-5" placeholder="••••••••" />
                                <i class="bi bi-eye position-absolute show-pass-icon" onclick="togglePassword('Password', this)"></i>
                            </div>
                            <span asp-validation-for="Password" class="text-danger small mt-1 d-block fw-semibold"></span>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="ConfirmPassword" class="form-label text-dark fw-bold mb-2" style="font-size: 0.9rem; letter-spacing: 0.5px; text-transform: uppercase;">Confirm</label>
                            <div class="position-relative">
                                <i class="bi bi-shield-check position-absolute auth-icon"></i>
                                <input asp-for="ConfirmPassword" type="password" id="ConfirmPassword" class="form-control auth-input pe-5" placeholder="••••••••" />
                                <i class="bi bi-eye position-absolute show-pass-icon" onclick="togglePassword('ConfirmPassword', this)"></i>
                            </div>
                            <span asp-validation-for="ConfirmPassword" class="text-danger small mt-1 d-block fw-semibold"></span>
                        </div>
                    </div>

                    <div class="d-grid mb-4">
                        <button type="submit" class="btn btn-primary btn-lg auth-submit shadow-sm py-3 border-0 d-flex justify-content-center align-items-center gap-2" style="font-size: 1.05rem; letter-spacing: 0.5px; text-transform: uppercase; font-weight: 700;">
                            <i class="bi bi-person-plus fs-5"></i> Create Account
                        </button>
                    </div>
                </form>

                <!-- Footer Link -->
                <div class="text-center mt-auto pb-4">
                    <p class="mb-0 fw-medium text-muted" style="font-size: 1rem;">
                        Already have an account? <a asp-action="Login" class="text-decoration-none fw-bold" style="color: var(--brand-primary); padding-bottom: 2px; border-bottom: 2px solid var(--brand-primary);">Sign In</a>
                    </p>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    body {
        margin: 0;
        padding: 0;
        background-color: #ffffff !important;
        overflow-x: hidden;
    }

    /* Hide the main layout header/footer for auth pages to give full screen experience */
    header, footer {
        display: none !important;
    }

    .auth-split-container {
        height: 100vh;
        width: 100%;
    }

    .overlay {
        position: absolute;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        background: linear-gradient(135deg, rgba(15, 118, 110, 0.85) 0%, rgba(17, 24, 39, 0.9) 100%);
    }

    .auth-form-wrapper {
        background-color: #ffffff;
        padding: 2rem 0;
        overflow-y: auto;
    }

    .auth-form-inner {
        max-width: 580px;
    }

    .auth-input {
        height: 56px;
        border-radius: 12px;
        border: 1.5px solid #E5E7EB;
        padding-left: 3.5rem;
        font-size: 1.05rem;
        transition: all 0.3s ease;
        background-color: #F9FAFB;
        color: #111827;
    }

    .auth-input:focus {
        border-color: var(--brand-primary) !important;
        box-shadow: 0 0 0 4px rgba(15, 118, 110, 0.1) !important;
        background-color: #ffffff;
    }

    .auth-icon {
        left: 1.4rem; 
        top: 50%; 
        transform: translateY(-50%); 
        font-size: 1.25rem; 
        color: #9CA3AF;
        z-index: 5;
    }

    .show-pass-icon {
        right: 1.4rem; 
        top: 50%; 
        transform: translateY(-50%); 
        font-size: 1.25rem; 
        cursor: pointer; 
        color: #9CA3AF;
        z-index: 5;
        transition: color 0.2s;
    }
    
    .show-pass-icon:hover {
        color: var(--brand-primary);
    }

    .auth-submit {
        border-radius: 12px;
        transition: all 0.3s ease;
        background-color: var(--brand-primary);
    }

    .auth-submit:hover {
        background-color: var(--brand-primary-hover) !important;
        transform: translateY(-2px);
        box-shadow: 0 10px 25px rgba(15, 118, 110, 0.25) !important;
    }

    .validation-summary-box {
        background-color: #FEF2F2;
        border: 1px solid #FCA5A5;
        border-radius: 12px;
        padding: 1.2rem;
        color: #B91C1C;
        font-size: 0.95rem;
    }
    
    .validation-summary-box ul {
        margin: 0; padding-left: 1.2rem;
    }
</style>

<script>
    function togglePassword(id, icon) {
        const input = document.getElementById(id);
        if (input.type === 'password') {
            input.type = 'text';
            icon.classList.replace('bi-eye', 'bi-eye-slash');
        } else {
            input.type = 'password';
            icon.classList.replace('bi-eye-slash', 'bi-eye');
        }
    }
</script>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
