@{
    ViewData["Title"] = "Email Sent";
}

<div class="d-flex justify-content-center align-items-center w-100 py-2" style="min-height: calc(100vh - 150px);">
    <div class="w-100 px-3" style="max-width: 500px;">
        <div class="card border-0 p-3 p-md-4 text-center" style="border-radius: 20px; box-shadow: 0 10px 40px rgba(0,0,0,0.05); background-color: #ffffff;">
            <div class="mb-4">
                <div class="d-inline-flex align-items-center justify-content-center mb-4" style="width: 90px; height: 90px; border-radius: 50%; background: linear-gradient(135deg, #eff6ff 0%, #dbeafe 100%); border: 4px solid #ffffff; box-shadow: 0 10px 20px rgba(37, 99, 235, 0.1);">
                    <i class="bi bi-send-check text-primary" style="font-size: 2.5rem;"></i>
                </div>
                <h2 class="fw-bolder mb-2" style="color: #0f172a; letter-spacing: -0.5px; font-size: 1.8rem;">Check Your Email</h2>
                <p class="mb-0" style="color: #64748b; font-size: 1rem; line-height: 1.6;">
                    We've sent a secure password reset link to your email. <br class="d-none d-md-block"> Please check your inbox to continue.
                </p>
            </div>

            <div class="d-grid mb-3">
                <a asp-action="Login" class="btn text-white btn-lg fw-bold shadow-sm d-flex justify-content-center align-items-center gap-2 login-btn" style="background-color: #2563eb; border-radius: 12px; font-size: 1rem; padding: 0.7rem; transition: all 0.3s ease;">
                    <i class="bi bi-arrow-left"></i> Back to Login
                </a>
            </div>

            <div class="pt-3 border-top" style="border-color: #f1f5f9 !important;">
                <p class="mb-0 fw-medium" style="color: #64748b; font-size: 0.9rem;">
                    Didn't receive an email? <a asp-action="ForgotPassword" class="text-decoration-none fw-bold" style="color: #2563eb;">Send again</a>
                </p>
            </div>
        </div>
    </div>
</div>

<style>
    body {
        background-color: #F8FAFC !important;
        overflow: hidden !important;
    }
    .login-btn:hover {
        background-color: #1d4ed8 !important;
        transform: translateY(-2px);
        box-shadow: 0 6px 20px rgba(37, 99, 235, 0.25) !important;
    }
    .bi-send-check {
        animation: float 3s ease-in-out infinite;
    }
    @@keyframes float {
        0% { transform: translateY(0px); }
        50% { transform: translateY(-5px); }
        100% { transform: translateY(0px); }
    }
</style>
