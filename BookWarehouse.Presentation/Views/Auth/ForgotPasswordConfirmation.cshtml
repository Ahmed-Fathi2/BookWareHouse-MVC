@{
    ViewData["Title"] = "Email Sent";
}

<div class="auth-wrapper d-flex align-items-center justify-content-center py-4">
    <div class="auth-container p-3 p-md-0 w-100" style="max-width: 500px;">
        <div class="card auth-card border-0 shadow-lg text-center" style="border-radius: 24px; overflow: hidden; background-color: #ffffff;">
            <div class="card-body p-4 p-md-5">
                <div class="mb-4">
                    <div class="d-inline-flex align-items-center justify-content-center mb-4" style="width: 90px; height: 90px; border-radius: 50%; background: rgba(15, 118, 110, 0.1); border: 4px solid #ffffff; box-shadow: 0 10px 20px rgba(15, 118, 110, 0.1);">
                        <i class="bi bi-send-check" style="font-size: 2.5rem; color: var(--brand-primary);"></i>
                    </div>
                    <h2 class="fw-bolder mb-2 text-dark" style="letter-spacing: -0.8px; font-size: 1.8rem;">Check Your Email</h2>
                    <p class="mb-0 text-muted" style="font-size: 1rem; line-height: 1.6;">
                        We've sent a secure password reset link to your email. <br class="d-none d-md-block"> Please check your inbox to continue.
                    </p>
                </div>

                <div class="d-grid mb-2">
                    <a asp-action="Login" class="btn btn-primary btn-lg auth-submit shadow-sm d-flex justify-content-center align-items-center gap-2" style="font-size: 1rem; padding: 0.7rem;">
                        <i class="bi bi-arrow-left"></i> Back to Login
                    </a>
                </div>
            </div>

            <!-- Footer Link -->
            <div class="p-4 bg-light border-top text-center" style="background-color: #F9FAFB !important;">
                <p class="mb-0 fw-medium text-muted" style="font-size: 0.95rem;">
                    Didn't receive an email? <a asp-action="ForgotPassword" class="text-decoration-none fw-bold" style="color: var(--brand-primary);">Send again</a>
                </p>
            </div>
        </div>
    </div>
</div>

<style>
    header, footer {
        display: none !important;
    }

    body {
        background-color: var(--bg-main) !important;
        height: 100vh;
    }

    .auth-wrapper {
        min-height: calc(100vh - 120px);
    }

    .auth-submit {
        border-radius: 12px;
        transition: all 0.3s ease;
    }

    .auth-submit:hover {
        background-color: var(--brand-primary-hover) !important;
        transform: translateY(-2px);
        box-shadow: 0 10px 20px rgba(15, 118, 110, 0.2) !important;
    }

    .bi-send-check {
        animation: float 3s ease-in-out infinite;
    }
    
    @@keyframes float {
        0% { transform: translateY(0px); }
        50% { transform: translateY(-5px); }
        100% { transform: translateY(0px); }
    }
</style>
