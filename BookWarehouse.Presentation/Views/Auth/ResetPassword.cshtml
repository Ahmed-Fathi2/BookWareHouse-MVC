@model ResetPasswordVM

@{
    ViewData["Title"] = "Reset Password";
}

<div class="auth-wrapper d-flex align-items-center justify-content-center py-4">
    <div class="auth-container p-3 p-md-0 w-100" style="max-width: 500px;">
        <div class="card auth-card border-0 shadow-lg" style="border-radius: 24px; overflow: hidden; background-color: #ffffff;">
            <div class="card-body p-4 p-md-5">
                
                <!-- Logo & Header -->
                <div class="text-center mb-4">
                    <div class="bg-primary text-white rounded-4 d-inline-flex align-items-center justify-content-center mb-3 shadow-sm" style="width: 54px; height: 54px;">
                        <i class="bi bi-lock" style="font-size: 1.8rem;"></i>
                    </div>
                    <h2 class="fw-bolder mb-1 text-dark" style="letter-spacing: -0.8px; font-size: 1.75rem;">Reset Password</h2>
                    <p class="text-muted mb-0" style="font-size: 0.95rem;">Please enter your new password</p>
                </div>

                <form asp-action="ResetPassword" method="post">
                    <div asp-validation-summary="ModelOnly" class="validation-summary-box mb-4"></div>
                    <input asp-for="Token" type="hidden" />
                    <input asp-for="Email" type="hidden" />

                    <!-- New Password Field -->
                    <div class="mb-4">
                        <label asp-for="NewPassword" class="form-label text-dark fw-bold mb-2" style="font-size: 0.85rem; letter-spacing: 0.3px; text-transform: uppercase;">New Password</label>
                        <div class="position-relative">
                            <i class="bi bi-shield-lock position-absolute auth-icon"></i>
                            <input asp-for="NewPassword" type="password" class="form-control auth-input pe-5" placeholder="••••••••" id="NewPassword" />
                            <i class="bi bi-eye position-absolute show-pass-icon" onclick="togglePassword('NewPassword', this)"></i>
                        </div>
                        <span asp-validation-for="NewPassword" class="text-danger small mt-1 d-block fw-semibold"></span>
                    </div>

                    <!-- Confirm Password Field -->
                    <div class="mb-4">
                        <label asp-for="ConfirmPassword" class="form-label text-dark fw-bold mb-2" style="font-size: 0.85rem; letter-spacing: 0.3px; text-transform: uppercase;">Confirm Password</label>
                        <div class="position-relative">
                            <i class="bi bi-shield-check position-absolute auth-icon"></i>
                            <input asp-for="ConfirmPassword" type="password" class="form-control auth-input pe-5" placeholder="••••••••" id="ConfirmPassword" />
                            <i class="bi bi-eye position-absolute show-pass-icon" onclick="togglePassword('ConfirmPassword', this)"></i>
                        </div>
                        <span asp-validation-for="ConfirmPassword" class="text-danger small mt-1 d-block fw-semibold"></span>
                    </div>

                    <!-- Submit Button -->
                    <div class="d-grid mb-2">
                        <button type="submit" class="btn btn-primary btn-lg auth-submit shadow-sm py-3 border-0" style="font-size: 1rem; letter-spacing: 0.5px;">
                            Reset Password <i class="bi bi-check2-circle ms-2"></i>
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

<script>
    function togglePassword(id, icon) {
        const input = document.getElementById(id);
        if (input.type === 'password') {
            input.type = 'text';
            icon.classList.replace('bi-eye', 'bi-eye-slash');
        } else {
            input.type = 'password';
            icon.classList.replace('bi-eye-slash', 'bi-eye');
        }
    }
</script>

<style>
    header, footer {
        display: none !important;
    }

    body {
        background-color: var(--bg-main) !important;
        height: 100vh;
    }

    .auth-wrapper {
        min-height: calc(100vh - 120px);
    }

    .auth-input {
        height: 52px;
        border-radius: 12px;
        border: 1.5px solid var(--border-color);
        padding-left: 3.2rem;
        font-size: 1rem;
        transition: all 0.25s ease;
        background-color: #ffffff;
    }

    .auth-input:focus {
        border-color: var(--brand-primary) !important;
        box-shadow: 0 0 0 4px rgba(15, 118, 110, 0.1) !important;
        background-color: #ffffff;
    }

    .auth-icon {
        left: 1.2rem; 
        top: 50%; 
        transform: translateY(-50%); 
        font-size: 1.1rem; 
        color: var(--brand-muted);
    }

    .show-pass-icon {
        right: 1.2rem; 
        top: 50%; 
        transform: translateY(-50%); 
        font-size: 1.1rem; 
        cursor: pointer; 
        color: var(--brand-muted);
    }

    .auth-submit {
        border-radius: 12px;
        transition: all 0.3s ease;
    }

    .auth-submit:hover {
        background-color: var(--brand-primary-hover) !important;
        transform: translateY(-2px);
        box-shadow: 0 10px 20px rgba(15, 118, 110, 0.2) !important;
    }

    .validation-summary-box {
        background-color: #FEF2F2;
        border-radius: 12px;
        padding: 1rem;
        color: #B91C1C;
        font-size: 0.85rem;
    }
    
    .validation-summary-box ul {
        margin: 0; padding-left: 1.2rem;
    }
</style>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
